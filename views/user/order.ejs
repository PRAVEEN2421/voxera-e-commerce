<%- include("../../views/partials/user/headers") %>
    <style>
        :root {
            --primary-color: #00f2ea;
            --primary-dark: #00d6d0;
            --text-dark: #333;
            --text-light: #666;
            --border-color: #eee;
            --bg-light: #fafafa;
            --bg-white: #ffffff;
            --shadow: 0 4px 12px rgba(0, 0, 0, 0.05);
            --radius: 12px;
            --radius-sm: 8px;
            --spacing-sm: 10px;
            --spacing-md: 20px;
            --spacing-lg: 30px;
        }

        * {
            box-sizing: border-box;
            margin: 0;
            padding: 0;
        }

        body {
            font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Oxygen, Ubuntu, Cantarell, 'Open Sans', 'Helvetica Neue', sans-serif;
            background-color: var(--bg-light);
            color: var(--text-dark);
            line-height: 1.6;
        }

        .page-content {
            width: 100%;
            margin: 0 auto;
            padding: 20px;
        }

        .Pcontainer {
            display: flex;
            gap: 30px;
            padding: 10px;
        }

        .sidebar {
            width: 320px;
            background-color: var(--bg-white);
            border-radius: var(--radius);
            padding: var(--spacing-md);
            box-shadow: var(--shadow);
            position: sticky;
            top: 20px;
            height: fit-content;
        }

        .main-content {
            flex: 1;
            min-width: 0;
        }

        .user {
            display: flex;
            align-items: center;
            gap: 15px;
            padding-bottom: 20px;
            border-bottom: 1px solid var(--border-color);
            margin-bottom: 20px;
        }

        .user-avatar {
            width: 64px;
            height: 64px;
            background-color: #f8e4e6;
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 24px;
            font-weight: bold;
            color: #e91e63;
            box-shadow: 0 2px 8px rgba(233, 30, 99, 0.2);
        }

        .user-info {
            display: flex;
            flex-direction: column;
        }

        .user-name {
            font-weight: 600;
            font-size: 18px;
            margin-bottom: 4px;
        }

        .user-email {
            color: var(--text-light);
            font-size: 14px;
        }

        .menu-section {
            margin-bottom: var(--spacing-lg);
        }

        .menu-title {
            font-weight: 600;
            margin-bottom: 15px;
            color: var(--text-light);
            font-size: 14px;
            text-transform: uppercase;
            letter-spacing: 0.5px;
        }

        .menu-section a {
            color: #333;
            text-decoration: none !important;
            font-weight: 600;
            font-size: 16px;
        }

        .menu-item {
            display: flex;
            align-items: center;
            padding: 12px 15px;
            margin-bottom: 8px;
            border-radius: var(--radius-sm);
            cursor: pointer;
            color: var(--text-dark);
            text-decoration: none;
            transition: all 0.2s ease;
            font-weight: 500;
        }

        .menu-item.active {
            background-color: rgba(0, 242, 234, 0.1);
            color: var(--primary-color);
            font-weight: 600;
        }

        .menu-item:hover:not(.active) {
            background-color: rgba(0, 0, 0, 0.03);
            transform: translateX(3px);
        }

        .logout-item {
            margin-top: 40px;
            color: #ff5252;
        }

        h1 {
            font-size: 28px;
            margin-bottom: 25px;
            font-weight: 700;
        }

        h2 {
            font-size: 20px;
            margin-bottom: 20px;
            font-weight: 600;
        }

        .orders-section {
            margin-bottom: 30px;
            background-color: var(--bg-white);
            padding: 30px;
            border-radius: var(--radius);
            box-shadow: var(--shadow);
        }

        .section-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 25px;
        }

        .orders-table {
            width: 100%;
            border-collapse: collapse;
        }

a{
    text-decoration: none !important;
}

        .orders-table th,
        .orders-table td {
            padding: 15px;
            text-align: left;
            border-bottom: 1px solid var(--border-color);
        }

        .orders-table th {
            font-weight: 600;
            color: var(--text-light);
            font-size: 14px;
            text-transform: uppercase;
            letter-spacing: 0.5px;
        }

        .orders-table tr:last-child td {
            border-bottom: none;
        }

        .status-badge {
            display: inline-block;
            padding: 5px 12px;
            border-radius: 20px;
            font-size: 14px;
            font-weight: 500;
        }

        .status-delivered {
            background-color: #e3f9e5;
            color: #1b873d;
        }

        .status-shipped {
            background-color: #e6f6ff;
            color: #0085ff;
        }

        .status-processing {
            background-color: #fff4e5;
            color: #ff8800;
        }

        .status-cancelled {
            background-color: #ffebee;
            color: #d32f2f;
        }

        .view-button {
            display: inline-flex;
            align-items: center;
            padding: 8px 16px;
            border-radius: var(--radius-sm);
            font-size: 14px;
            font-weight: 500;
            background-color: var(--primary-color);
            color: #000;
            text-decoration: none;
            transition: all 0.2s ease;
        }

        .view-button:hover {
            background-color: var(--primary-dark);
            transform: translateY(-2px);
            box-shadow: 0 4px 8px rgba(0, 0, 0, 0.1);
        }

        .view-button svg {
            margin-right: 6px;
        }

        .empty-orders {
            text-align: center;
            padding: 40px;
            color: var(--text-light);
        }

        .empty-orders svg {
            width: 60px;
            height: 60px;
            margin-bottom: 20px;
            color: #ddd;
        }

        .empty-orders p {
            font-size: 18px;
            margin-bottom: 20px;
        }

        .shop-now-btn {
            display: inline-flex;
            align-items: center;
            padding: 12px 24px;
            border-radius: var(--radius-sm);
            font-size: 16px;
            font-weight: 500;
            background-color: var(--primary-color);
            color: #000;
            text-decoration: none;
            transition: all 0.2s ease;
        }

        .shop-now-btn:hover {
            background-color: var(--primary-dark);
        }

        .toast-container {
            position: fixed;
            top: 20px;
            right: 20px;
            z-index: 9999;
        }

        .toast {
            display: none;
            background-color: #333;
            color: white;
            padding: 15px 25px;
            border-radius: var(--radius);
            font-size: 16px;
            box-shadow: 0 8px 20px rgba(0, 0, 0, 0.2);
            opacity: 0;
            transform: translateX(100%);
            animation: slideInFromRight 0.8s ease-out forwards;
        }

        .toast.success {
            background-color: #28a745;
        }

        .toast.error {
            background-color: #dc3545;
        }

        /* Pagination Styles */
        .pagination {
            display: flex;
            justify-content: center;
            margin-top: 30px;
            align-items: center;
            gap: 5px;
        }

        .pagination-info {
            margin-right: 15px;
            font-size: 14px;
            color: var(--text-light);
        }

        .pagination-btn {
            display: inline-flex;
            align-items: center;
            justify-content: center;
            width: 40px;
            height: 40px;
            border-radius: 50%;
            font-size: 14px;
            font-weight: 500;
            background-color: var(--bg-white);
            color: var(--text-dark);
            text-decoration: none;
            transition: all 0.2s ease;
            border: 1px solid var(--border-color);
        }

        .pagination-btn.active {
            background-color: var(--primary-color);
            color: #000;
            font-weight: 600;
            border: none;
        }

        .pagination-btn:hover:not(.active):not(.disabled) {
            background-color: #f0f0f0;
            transform: translateY(-2px);
        }

        .pagination-btn.disabled {
            opacity: 0.5;
            cursor: not-allowed;
        }

        .pagination-nav {
            display: flex;
            align-items: center;
            gap: 10px;
        }

        @keyframes slideInFromRight {
            0% {
                opacity: 0;
                transform: translateX(100%);
            }
            100% {
                opacity: 1;
                transform: translateX(0);
            }
        }

        @keyframes slideOutToRight {
            0% {
                opacity: 1;
                transform: translateX(0);
            }
            100% {
                opacity: 0;
                transform: translateX(100%);
            }
        }

        /* Responsive styles */
        @media (max-width: 990px) {
            .Pcontainer {
                flex-direction: column;
            }

            .sidebar {
                width: 100%;
                position: static;
                margin-bottom: 20px;
            }

            .user {
                padding-bottom: 15px;
                margin-bottom: 15px;
            }
        }

        @media (max-width: 768px) {
            .orders-table {
                display: block;
                overflow-x: auto;
            }

            .orders-section {
                padding: 20px;
            }

            .pagination {
                flex-wrap: wrap;
            }
        }

        @media (max-width: 480px) {
            .section-header {
                flex-direction: column;
                align-items: flex-start;
                gap: 10px;
            }

            .view-button {
                width: 100%;
                justify-content: center;
            }

            .pagination-info {
                width: 100%;
                text-align: center;
                margin-bottom: 10px;
            }
        }
    </style>

<body>
    
    
    <div class="toast-container"></div>

    <div class="page-content">
        <div class="Pcontainer">
            <div class="sidebar">
                <div class="user">
                    <div class="user-avatar">
                        <%= userVer.name.charAt(0).toUpperCase() %>
                    </div>
                    <div class="user-info">
                        <div class="user-name"><%= userVer.name %></div>
                        <div class="user-email"><%= userVer.email %></div>
                    </div>
                </div>

                <div class="menu-section">
                    <a href="/profile" class="menu-item">
                        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="margin-right: 10px;">
                            <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"></path>
                            <circle cx="12" cy="7" r="4"></circle>
                        </svg>
                        Personal Info
                    </a>
                    <a href="/address" class="menu-item">
                        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="margin-right: 10px;">
                            <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"></path>
                            <circle cx="12" cy="10" r="3"></circle>
                        </svg>
                        Addresses
                    </a>
                    <a href="/wishlist" class="menu-item">
                        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="margin-right: 10px;">
                            <path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78L12 21.23l8.84-8.84a5.5 5.5 0 0 0 0-7.78z"></path>
                        </svg>
                        Wishlist
                    </a>
                    <a href="/wallet" class="menu-item">
                        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="margin-right: 10px;">
                            <rect x="2" y="5" width="20" height="14" rx="2"></rect>
                            <line x1="16" y1="12" x2="16" y2="12"></line>
                        </svg>
                        Wallet
                    </a>
                    <a href="/orders" class="menu-item active">
                        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="margin-right: 10px;">
                            <path d="M6 2L3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4z"></path>
                            <line x1="3" y1="6" x2="21" y2="6"></line>
                            <path d="M16 10a4 4 0 0 1-8 0"></path>
                        </svg>
                        Orders
                    </a>

                    <a href="#" class="menu-item logout-item" onclick="document.getElementById('logoutForm').submit(); return false;">
                        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="margin-right: 10px;">
                            <path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"></path>
                            <polyline points="16 17 21 12 16 7"></polyline>
                            <line x1="21" y1="12" x2="9" y2="12"></line>
                        </svg>
                        Log out
                    </a>
                </div>

                <form id="logoutForm" action="/logout" method="post" style="display: none"></form>
            </div>

            <div class="main-content">
                <div class="orders-section">
                    <div class="section-header">
                        <h2>My Orders</h2>
                    </div>

                    <% if (orders && orders.length > 0) { %>
                        <div class="table-responsive">
                            <table class="orders-table">
                                <thead>
                                    <tr>
                                        <th>S No</th>
                                        <th>Order ID</th>
                                        <th>Date</th>
                                        <th>Items</th>
                                        <th>Status</th>
                                        <th>Total Amount</th>
                                        <th>Actions</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    <% orders.forEach((order, index) => { %>
                                    <tr>
                                        <td><%= ((pagination.page - 1) * pagination.limit) + index + 1 %></td>
                                        <td>#<%= order.orderId %></td>
                                        <td><%= order.createdAt.toLocaleDateString() %></td>
                                        <td><%= order.products.length %></td>
                                        
                                        <td>
                                            <span class="status-badge status-<%= order.status.toLowerCase() %>">
                                                <%= order.status %>
                                            </span>
                                        </td>
                                        <td>₹<%= order.priceDetails.total.toFixed(2) %></td>
                                        <td>
                                            <a href="/orderview/<%= order._id %>" class="view-button">
                                                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                                    <path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"></path>
                                                    <circle cx="12" cy="12" r="3"></circle>
                                                </svg>
                                                View
                                            </a>
                                        </td>
                                    </tr>
                                    <% }) %>
                                </tbody>
                            </table>
                        </div>
                        
                        <!-- Pagination Section -->
                        <% if (pagination.totalPages > 1) { %>
                        <div class="pagination">
                            <div class="pagination-info">
                                Showing <%= ((pagination.page - 1) * pagination.limit) + 1 %> to 
                                <%= Math.min(pagination.page * pagination.limit, pagination.totalItems) %> 
                                of <%= pagination.totalItems %> orders
                            </div>
                            <div class="pagination-nav">
                                <a href="/orders?page=1" class="pagination-btn <%= pagination.page === 1 ? 'disabled' : '' %>" <%= pagination.page === 1 ? 'aria-disabled="true"' : '' %>>
                                    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                        <polyline points="11 17 6 12 11 7"></polyline>
                                        <polyline points="18 17 13 12 18 7"></polyline>
                                    </svg>
                                </a>
                                <a href="/orders?page=<%= pagination.page - 1 %>" class="pagination-btn <%= pagination.page === 1 ? 'disabled' : '' %>" <%= pagination.page === 1 ? 'aria-disabled="true"' : '' %>>
                                    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                        <polyline points="15 18 9 12 15 6"></polyline>
                                    </svg>
                                </a>
                                
                                <% 
                                let startPage = Math.max(1, pagination.page - 2);
                                let endPage = Math.min(pagination.totalPages, pagination.page + 2);
                                
                                // Ensure we always show 5 pages when possible
                                if (endPage - startPage < 4) {
                                    if (startPage === 1) {
                                        endPage = Math.min(5, pagination.totalPages);
                                    } else {
                                        startPage = Math.max(1, pagination.totalPages - 4);
                                    }
                                }
                                
                                for (let i = startPage; i <= endPage; i++) { %>
                                    <a href="/orders?page=<%= i %>" class="pagination-btn <%= pagination.page === i ? 'active' : '' %>">
                                        <%= i %>
                                    </a>
                                <% } %>
                                
                                <a href="/orders?page=<%= pagination.page + 1 %>" class="pagination-btn <%= pagination.page === pagination.totalPages ? 'disabled' : '' %>" <%= pagination.page === pagination.totalPages ? 'aria-disabled="true"' : '' %>>
                                    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                        <polyline points="9 18 15 12 9 6"></polyline>
                                    </svg>
                                </a>
                                <a href="/orders?page=<%= pagination.totalPages %>" class="pagination-btn <%= pagination.page === pagination.totalPages ? 'disabled' : '' %>" <%= pagination.page === pagination.totalPages ? 'aria-disabled="true"' : '' %>>
                                    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                        <polyline points="13 17 18 12 13 7"></polyline>
                                        <polyline points="6 17 11 12 6 7"></polyline>
                                    </svg>
                                </a>
                            </div>
                        </div>
                        <% } %>
                    <% } else { %>
                        <div class="empty-orders">
                            <svg xmlns="http://www.w3.org/2000/svg" width="60" height="60" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                                <path d="M6 2L3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4z"></path>
                                <line x1="3" y1="6" x2="21" y2="6"></line>
                                <path d="M16 10a4 4 0 0 1-8 0"></path>
                            </svg>
                            <p>You haven't placed any orders yet</p>
                            <a href="/shop" class="shop-now-btn">Shop Now</a>
                        </div>
                    <% } %>
                </div>
            </div>
        </div>
    </div>

    <%- include("../../views/partials/user/footers") %>

    <script>
        document.addEventListener('DOMContentLoaded', function() {
            // Show toast notification
            function showToast(message, type) {
                const toastContainer = document.querySelector(".toast-container");
                const toast = document.createElement("div");
                toast.className = `toast ${type}`;
                toast.textContent = message;
                toastContainer.appendChild(toast);

                setTimeout(() => {
                    toast.style.display = "block";
                    setTimeout(() => {
                        toast.style.animation = "slideOutToRight 0.8s ease-out forwards";
                        setTimeout(() => {
                            toast.remove();
                        }, 800);
                    }, 3000);
                }, 100);
            }
            
            // Get URL parameters to check for success/error messages
            const urlParams = new URLSearchParams(window.location.search);
            const successMsg = urlParams.get('success');
            const errorMsg = urlParams.get('error');
            
            if (successMsg) {
                showToast(decodeURIComponent(successMsg), 'success');
            }
            
            if (errorMsg) {
                showToast(decodeURIComponent(errorMsg), 'error');
            }
        });
    </script>
</body>
</html>