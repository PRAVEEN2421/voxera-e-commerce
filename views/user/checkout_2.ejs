<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Voxera - Payment</title>
    <link rel="icon" href="/img/icon.png" type="image/png" />
    <!-- Toast Notification CSS -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/toastify-js/src/toastify.min.css">
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
            font-family: 'Poppins', sans-serif;
        }

        body {
            background-color: #f5f7fb;
            color: #2d3748;
            line-height: 1.6;
        }

        .container {
            max-width: 1100px;
            margin: 0 auto;
            padding: 30px 20px;
        }

        /* Checkout Header Styles */
        .checkout-header {
            margin-bottom: 40px;
            text-align: center;
        }

        .checkout-header h1 {
            font-size: 32px;
            font-weight: 700;
            margin-bottom: 15px;
            color: #303b5a;
            letter-spacing: -0.5px;
        }

        /* Progress Bar */
        .checkout-progress {
            position: relative;
            margin: 40px auto;
            max-width: 600px;
        }

        .progress-bar {
            position: relative;
            display: flex;
            justify-content: space-between;
            counter-reset: step;
        }

        .progress-bar::before {
            content: "";
            position: absolute;
            top: 20px;
            left: 0;
            width: 100%;
            height: 3px;
            background-color: #e2e8f0;
            z-index: 1;
        }

        .progress-bar::after {
            content: "";
            position: absolute;
            top: 20px;
            left: 0;
            width: 66.66%;
            height: 3px;
            background-color: #00f2ea;
            z-index: 1;
            transition: width 0.3s ease;
        }

        .step {
            position: relative;
            z-index: 2;
            text-align: center;
            width: 40px;
            height: 40px;
        }

        .step-icon {
            width: 40px;
            height: 40px;
            border-radius: 50%;
            background-color: #e2e8f0;
            color: #94a3b8;
            display: flex;
            align-items: center;
            justify-content: center;
            font-weight: 600;
            margin-bottom: 10px;
            transition: all 0.3s ease;
        }

        .step.active .step-icon {
            background-color: #00f2ea;
            color: #fff;
            box-shadow: 0 0 0 5px rgba(0, 242, 234, 0.2);
        }

        .step.completed .step-icon {
            background-color: #10b981;
            color: #fff;
        }

        .step-label {
            position: absolute;
            top: 45px;
            left: 50%;
            transform: translateX(-50%);
            font-size: 14px;
            font-weight: 500;
            white-space: nowrap;
            color: #94a3b8;
        }

        .step.active .step-label {
            color: #334155;
            font-weight: 600;
        }

        /* Checkout Content */
        .checkout-content {
            background-color: #fff;
            border-radius: 16px;
            box-shadow: 0 10px 30px rgba(0, 0, 0, 0.05);
            padding: 40px;
            margin-bottom: 30px;
            transition: all 0.3s ease;
        }

        .checkout-content:hover {
            box-shadow: 0 15px 40px rgba(0, 0, 0, 0.08);
        }

        .section-title {
            font-size: 24px;
            font-weight: 600;
            margin-bottom: 25px;
            color: #303b5a;
            display: flex;
            align-items: center;
        }

        .section-title svg {
            margin-right: 10px;
            color: #00f2ea;
        }

        /* Address Display Styles */
        .order-summary {
            margin-bottom: 30px;
            border-bottom: 1px solid #e2e8f0;
            padding-bottom: 25px;
        }

        .order-section h3.section-title {
            font-size: 18px;
            margin-bottom: 15px;
            color: #475569;
            display: flex;
            align-items: center;
        }

        .address-display {
            background-color: #f8fafc;
            border-radius: 10px;
            padding: 15px 20px;
            border: 1px solid #e2e8f0;
            margin-bottom: 10px;
        }

        .address-display p {
            margin-bottom: 5px;
            color: #475569;
            font-size: 15px;
        }

        .change-address {
            display: inline-flex;
            align-items: center;
            color: #00f2ea;
            font-size: 14px;
            font-weight: 500;
            margin-top: 5px;
            cursor: pointer;
            transition: all 0.2s ease;
        }

        .change-address:hover {
            color: #00dad3;
            text-decoration: underline;
        }

        .change-address svg {
            margin-right: 5px;
            font-size: 16px;
        }

        /* Payment Methods Styles */
        .payment-methods {
            margin-bottom: 30px;
        }

        .payment-card {
            border: 1.5px solid #e2e8f0;
            border-radius: 12px;
            padding: 20px;
            margin-bottom: 15px;
            cursor: pointer;
            transition: all 0.3s ease;
            display: flex;
            align-items: flex-start;
            position: relative;
            overflow: hidden;
            width: 800px;
        }

        .payment-card:hover {
            border-color: #00f2ea;
            transform: translateY(-2px);
            box-shadow: 0 8px 20px rgba(0, 0, 0, 0.05);
        }

        .payment-card.selected {
            border-color: #00f2ea;
            background-color: rgba(0, 242, 234, 0.05);
        }

        .payment-card.selected::before {
            content: "";
            position: absolute;
            top: 0;
            left: 0;
            width: 4px;
            height: 100%;
            background-color: #00f2ea;
            border-top-left-radius: 10px;
            border-bottom-left-radius: 10px;
        }

        .payment-selector {
            margin-right: 15px;
            margin-top: 3px;
        }

        .payment-selector input[type="radio"] {
            width: 18px;
            height: 18px;
            accent-color: #00f2ea;
        }

        .payment-content {
            flex: 1;
        }

        .payment-header {
            display: flex;
            align-items: center;
            margin-bottom: 10px;
        }

        .payment-icon {
            width: 40px;
            height: 40px;
            margin-right: 15px;
            display: flex;
            align-items: center;
            justify-content: center;
            background-color: #f1f5f9;
            border-radius: 50%;
            color: #64748b;
        }

        .payment-title {
            font-weight: 600;
            font-size: 16px;
            color: #334155;
        }

        .payment-details {
            color: #64748b;
            font-size: 14px;
            padding-left: 55px;
            line-height: 1.5;
        }

        /* Disabled Payment Card */
        .payment-card.disabled {
            opacity: 0.6;
            cursor: not-allowed;
            position: relative;
        }

        .payment-card.disabled .payment-title,
        .payment-card.disabled .payment-details {
            color: #999;
        }

        .payment-card.disabled::after {
            content: "";
            position: absolute;
            top: 0;
            left: 0;
            right: 0;
            bottom: 0;
            background: transparent;
            z-index: 1;
        }

        /* Validation Styles */
        .payment-methods.no-selection {
            animation: pulse 1.5s infinite;
            position: relative;
        }

        @keyframes pulse {
            0% {
                box-shadow: 0 0 0 0 rgba(255, 82, 82, 0.4);
            }

            70% {
                box-shadow: 0 0 0 10px rgba(255, 82, 82, 0);
            }

            100% {
                box-shadow: 0 0 0 0 rgba(255, 82, 82, 0);
            }
        }

        .payment-methods.no-selection .payment-card:not(.disabled) {
            border-color: #ff5252;
        }

        /* Action Buttons */
        .checkout-actions {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-top: 30px;
            padding-top: 20px;
            border-top: 1px solid #e2e8f0;
        }

        .btn {
            padding: 12px 24px;
            border-radius: 10px;
            font-size: 16px;
            font-weight: 500;
            cursor: pointer;
            transition: all 0.3s ease;
            border: none;
            outline: none;
            text-decoration: none;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            min-width: 150px;
        }

        .btn svg {
            margin-right: 8px;
        }

        .btn-primary {
            background-color: #00f2ea;
            color: #0c4a47;
            box-shadow: 0 4px 15px rgba(0, 242, 234, 0.2);
        }

        .btn-primary:hover {
            background-color: #00dad3;
            transform: translateY(-2px);
            box-shadow: 0 8px 20px rgba(0, 242, 234, 0.25);
        }

        .btn-outline {
            background-color: transparent;
            border: 1.5px solid #cbd5e1;
            color: #64748b;
        }

        .btn-outline:hover {
            border-color: #94a3b8;
            color: #475569;
            background-color: #f8fafc;
        }

        /* Toast custom styles */
        .custom-toast {
            background-color: #28a745;
            color: white;
            padding: 15px 30px;
            border-radius: 12px;
            font-size: 16px;
            text-align: center;
            box-shadow: 0 8px 20px rgba(0, 0, 0, 0.2);
            opacity: 0;
        }

        .toast-error {
            background-color: #ff5252;
            color: white;
            padding: 15px 30px;
            border-radius: 12px;
            font-size: 16px;
            text-align: center;
            box-shadow: 0 8px 20px rgba(0, 0, 0, 0.2);
            opacity: 0;
        }

        /* Loading Styles */
        .loading {
            display: inline-block;
            width: 20px;
            height: 20px;
            border: 2px solid rgba(255, 255, 255, 0.3);
            border-radius: 50%;
            border-top-color: #fff;
            animation: spin 1s ease-in-out infinite;
            margin-right: 8px;
        }

        @keyframes spin {
            to {
                transform: rotate(360deg);
            }
        }

        /* Responsive styles */
        @media (max-width: 768px) {
            .container {
                padding: 20px 15px;
            }

            .checkout-content {
                padding: 25px;
            }

            .checkout-progress {
                max-width: 100%;
            }

            .step-label {
                font-size: 12px;
            }

            .checkout-actions {
                flex-direction: column;
                gap: 15px;
            }

            .checkout-actions .btn {
                width: 100%;
            }
        }
    </style>
</head>

<body>
    <div class="container">
        <div class="checkout-header">
            <h1>Checkout</h1>

            <div class="checkout-progress">
                <div class="progress-bar">
                    <div class="step completed">
                        <div class="step-icon">
                            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24"
                                fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"
                                stroke-linejoin="round">
                                <polyline points="20 6 9 17 4 12"></polyline>
                            </svg>
                        </div>
                        <div class="step-label">Shipping</div>
                    </div>
                    <div class="step active">
                        <div class="step-icon">2</div>
                        <div class="step-label">Payment</div>
                    </div>
                    <div class="step">
                        <div class="step-icon">3</div>
                        <div class="step-label">Confirmation</div>
                    </div>
                </div>
            </div>
        </div>

        <div class="checkout-content">
            <!-- Address Display Section -->
            <div class="order-summary">
                <div class="order-section">
                    <h3 class="section-title">
                        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none"
                            stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                            <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"></path>
                            <circle cx="12" cy="10" r="3"></circle>
                        </svg>
                        Shipping Address
                    </h3>
                    <div class="address-display">
                        <p><strong>Name: <%= name %></strong>
                            <%= address.phoneNumber %>
                        </p>
                        <p><strong>Phone: <%= phone %></strong>
                            <%= address.phoneNumber %>
                        </p>
                        <p>
                            <%= address.doorNo %>, <%= address.street %>
                        </p>
                        <p>
                            <%= address.city %>, <%= address.district %>
                        </p>
                        <p>
                            <%= address.pinCode %>
                        </p>
                    </div>
                    <div class="change-address">
                        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none"
                            stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                            <path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"></path>
                            <path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"></path>
                        </svg>
                        Change Address
                    </div>
                </div>
            </div>

            <h2 class="section-title">
                <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none"
                    stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <rect x="1" y="4" width="22" height="16" rx="2" ry="2"></rect>
                    <line x1="1" y1="10" x2="23" y2="10"></line>
                </svg>
                Payment Method
            </h2>

            <div class="payment-methods">
                <% if (allowCOD) { %>
                    <div class="payment-card selected">
                        <div class="payment-selector">
                            <input type="radio" name="payment" value="Cash on delivery" checked>
                        </div>
                        <div class="payment-content">
                            <div class="payment-header">
                                <div class="payment-icon">
                                    <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24"
                                        fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"
                                        stroke-linejoin="round">
                                        <rect x="2" y="4" width="20" height="16" rx="2" ry="2"></rect>
                                        <line x1="6" y1="12" x2="18" y2="12"></line>
                                    </svg>
                                </div>
                                <div class="payment-title">Cash on Delivery</div>
                            </div>
                            <div class="payment-details">
                                Pay with cash when your order is delivered to your doorstep. No additional fees.
                            </div>
                        </div>
                    </div>
                    <% } else { %>
                        <div class="payment-card disabled">
                            <div class="payment-selector">
                                <input type="radio" name="payment" value="Cash on delivery" disabled>
                            </div>
                            <div class="payment-content">
                                <div class="payment-header">
                                    <div class="payment-icon">
                                        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18"
                                            viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"
                                            stroke-linecap="round" stroke-linejoin="round">
                                            <rect x="2" y="4" width="20" height="16" rx="2" ry="2"></rect>
                                            <line x1="6" y1="12" x2="18" y2="12"></line>
                                        </svg>
                                    </div>
                                    <div class="payment-title">Cash on Delivery</div>
                                </div>
                                <div class="payment-details">
                                    Not available for orders above ₹10,000
                                </div>
                            </div>
                        </div>
                        <% } %>
                            <div class="payment-card">
                                <div class="payment-selector">
                                    <input type="radio" name="payment" value="Razorpay">
                                </div>
                                <div class="payment-content">
                                    <div class="payment-header">
                                        <div class="payment-icon">
                                            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18"
                                                viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"
                                                stroke-linecap="round" stroke-linejoin="round">
                                                <rect x="1" y="4" width="22" height="16" rx="2" ry="2"></rect>
                                                <line x1="1" y1="10" x2="23" y2="10"></line>
                                            </svg>
                                        </div>
                                        <div class="payment-title">Online Payment (Razorpay)</div>
                                    </div>
                                    <div class="payment-details">
                                        Pay securely online using Razorpay. Accept credit/debit cards, UPI, net banking
                                        and more payment options.
                                    </div>
                                </div>
                            </div>
                            <% if (allowWallet) { %>
                                <div class="payment-card">
                                    <div class="payment-selector">
                                        <input type="radio" name="payment" value="Wallet">
                                    </div>
                                    <div class="payment-content">
                                        <div class="payment-header">
                                            <div class="payment-icon">
                                                <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18"
                                                    viewBox="0 0 24 24" fill="none" stroke="currentColor"
                                                    stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                                    <path
                                                        d="M19 5c1.1 0 2 .9 2 2v10c0 1.1-.9 2-2 2H5c-1.1 0-2-.9-2-2V7c0-1.1.9-2 2-2h14z">
                                                    </path>
                                                    <line x1="16" y1="12" x2="16" y2="12"></line>
                                                    <line x1="13" y1="12" x2="13" y2="12"></line>
                                                </svg>
                                            </div>
                                            <div class="payment-title">Wallet</div>
                                        </div>
                                     
                                        <div class="payment-details">
                                               <div>  <span> Wallet Balance:<span style="color: green;">₹<%= walBal.toFixed(2) %></span></span></div>
                                            Pay using your wallet balance. Add funds to your wallet for faster checkout
                                            in
                                            future purchases.
                                        </div>
                                    </div>
                                </div>
                                <% } else { %>
                                    <div class="payment-card disabled">
                                        <div class="payment-selector">
                                            <input type="radio" name="payment" value="Wallet" disabled>
                                        </div>
                                        <div class="payment-content">
                                            <div class="payment-header">
                                                <div class="payment-icon">
                                                    <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18"
                                                        viewBox="0 0 24 24" fill="none" stroke="currentColor"
                                                        stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                                        <path
                                                            d="M19 5c1.1 0 2 .9 2 2v10c0 1.1-.9 2-2 2H5c-1.1 0-2-.9-2-2V7c0-1.1.9-2 2-2h14z">
                                                        </path>
                                                        <line x1="16" y1="12" x2="16" y2="12"></line>
                                                        <line x1="13" y1="12" x2="13" y2="12"></line>
                                                    </svg>
                                                </div>
                                                <div class="payment-title">Wallet</div>
                                            </div>
                                            <div class="payment-details">
                                                <div>  <span> Wallet Balance:<span style="color: red;">₹<%= walBal.toFixed(2) %></span></span></div>
                                                Insufficient wallet balance. Please add funds or choose another payment method.
                                            </div>
                                        </div>
                                    </div>

                                    <%}%>
            </div>

            <div class="checkout-actions">
                <a href="/checkout" class="btn btn-outline">
                    <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none"
                        stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <line x1="19" y1="12" x2="5" y2="12"></line>
                        <polyline points="12 19 5 12 12 5"></polyline>
                    </svg>
                    Back to Shipping
                </a>
                <button id="continueToReview" class="btn btn-primary">
                    Continue to Review
                    <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none"
                        stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <line x1="5" y1="12" x2="19" y2="12"></line>
                        <polyline points="12 5 19 12 12 19"></polyline>
                    </svg>
                </button>
            </div>
        </div>
    </div>
    <%- include("../../views/partials/user/footers") %>
        <!-- Toast Notification JS -->
        <script src="https://cdn.jsdelivr.net/npm/toastify-js"></script>
        <script>
            document.addEventListener('DOMContentLoaded', function () {
                // Payment card selection - exclude disabled cards
                const paymentCards = document.querySelectorAll('.payment-card:not(.disabled)');
                const continueBtn = document.getElementById('continueToReview');
                const paymentMethods = document.querySelector('.payment-methods');

                // Set up click handlers for payment cards
                paymentCards.forEach(card => {
                    card.addEventListener('click', function () {
                        // Remove selected class from all cards
                        document.querySelectorAll('.payment-card').forEach(c => {
                            c.classList.remove('selected');
                        });

                        // Add selected class to clicked card
                        this.classList.add('selected');

                        // Check the radio button
                        const radio = this.querySelector('input[type="radio"]');
                        if (radio) {
                            radio.checked = true;
                        }
                    });
                });

                // Auto-select first available payment method
                if (paymentCards.length > 0 && !document.querySelector('.payment-card.selected')) {
                    paymentCards[0].click();
                }

                // Change address functionality
                document.querySelector('.change-address').addEventListener('click', function () {
                    window.location.href = '/checkout';
                });

                // Continue to review button handler
                continueBtn.addEventListener('click', async function () {
                    // Show loading state
                    const originalButtonText = continueBtn.innerHTML;
                    continueBtn.innerHTML = '<div class="loading"></div> Processing...';
                    continueBtn.disabled = true;

                    const selectedPayment = document.querySelector('input[name="payment"]:checked');

                    // Validate payment selection
                    if (!selectedPayment) {
                        // Highlight payment methods to show error
                        paymentMethods.classList.add('no-selection');

                        Toastify({
                            text: 'Please select a payment method',
                            duration: 3000,
                            className: "custom-toast toast-error",
                            close: true,
                            gravity: "top",
                            position: "right",
                        }).showToast();

                        // Remove highlight after 3 seconds
                        setTimeout(() => {
                            paymentMethods.classList.remove('no-selection');
                        }, 3000);

                        // Reset button state
                        continueBtn.innerHTML = originalButtonText;
                        continueBtn.disabled = false;
                        return;
                    }

                    try {
                        const response = await fetch('/payment', {
                            method: 'POST',
                            headers: {
                                'Content-Type': 'application/json',
                            },
                            body: JSON.stringify({
                                payment: selectedPayment.value
                            })
                        });

                        if (response.ok) {
                            window.location.href = '/review';
                        } else {
                            const result = await response.json();
                            throw new Error(result.message || 'Failed to proceed to review');
                        }
                    } catch (error) {
                        Toastify({
                            text: error.message,
                            duration: 3000,
                            className: "custom-toast toast-error",
                            close: true,
                            gravity: "top",
                            position: "right",
                        }).showToast();

                        // Reset button state
                        continueBtn.innerHTML = originalButtonText;
                        continueBtn.disabled = false;
                    }
                });
            });
        </script>
</body>

</html>