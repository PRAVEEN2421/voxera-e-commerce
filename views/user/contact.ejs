<!-- contact.ejs -->

<%- include("../../views/partials/user/headers") %>

  <style>
    .nav-menu #contact {
      color: #00c3ff;
    }
    .nav-menu #contact {
      font-size: 19px;
      font-weight: 700;
    }
    .contact-container {
      font-family: 'Roboto', sans-serif;
      color: #333333;
    }

    .hero-section {
      background-color: #1a1a2e;
      color: #fff;
      padding: 60px 0;
      text-align: center;
      margin-bottom: 40px;
    }

    .hero-section h1 {
      font-size: 2.5rem;
      margin-bottom: 10px;
      color: #00FFFB;
    }

    .tagline {
      font-size: 1.2rem;
      opacity: 0.9;
    }

    .pcontainer {
      max-width: 1200px;
      margin: 0 auto;
      padding: 0 20px;
    }

    .contact-grid {
      display: flex;
      flex-wrap: wrap;
      gap: 40px;
      margin-bottom: 60px;
    }

    .contact-form {
      flex: 1;
      min-width: 300px;
    }

    .contact-info {
      flex: 1;
      min-width: 300px;
    }

    .img-container {
      border-radius: 50px;
      background-image: url(/img/contact-logo.png);
      overflow: hidden;
      box-shadow: 0 2px 10px rgb(0, 0, 0);
      height: 282px;
      background-size: cover;
      background-position: center;
    }

    h2 {
      color: #1a1a2e;
      font-size: 1.8rem;
      margin: 30px 0 20px;
    }

    p {
      line-height: 1.6;
      margin-bottom: 15px;
    }

    .form-group {
      margin-bottom: 20px;
    }

    label {
      display: block;
      margin-bottom: 5px;
      font-weight: 500;
    }

    input,
    textarea {
      width: 100%;
      padding: 10px;
      border: 1px solid #ddd;
      border-radius: 4px;
      font-family: inherit;
      font-size: 1rem;
      transition: border 0.3s;
    }

    input:focus,
    textarea:focus {
      border-color: #00FFFB;
      outline: none;
    }

    textarea {
      min-height: 150px;
      resize: vertical;
    }

    button {
      background-color: #1a1a2e;
      color: white;
      border: none;
      padding: 12px 25px;
      font-size: 1rem;
      font-weight: 500;
      border-radius: 4px;
      cursor: pointer;
      transition: background-color 0.3s;
    }

    button:hover {
      background-color: #00FFFB;
      color: #1a1a2e;
    }

    .contact-card {
      background-color: #f8f9fa;
      padding: 20px;
      margin-bottom: 20px;
      border-radius: 8px;
      transition: transform 0.3s, box-shadow 0.3s;
    }

    .contact-card:hover {
      transform: translateY(-5px);
      box-shadow: 0 10px 20px rgba(0, 0, 0, 0.1);
    }

    .contact-icon {
      font-size: 1.5rem;
      color: #00FFFB;
      margin-bottom: 10px;
      display: inline-block;
      width: 40px;
    }

    .contact-details {
      display: flex;
      align-items: flex-start;
      margin-bottom: 10px;
    }

    .social-icons {
      display: flex;
      gap: 15px;
      margin-top: 20px;
    }

    .social-icon {
      font-size: 1.5rem;
      color: #1a1a2e;
      transition: color 0.3s;
    }

    .social-icon:hover {
      color: #00FFFB;
    }

    .thank-you {
      display: none;
      text-align: center;
      padding: 40px;
      background-color: #f8f9fa;
      border-radius: 8px;
      margin-top: 20px;
    }

    .success-icon {
      font-size: 3rem;
      color: #00FFFB;
      margin-bottom: 20px;
    }

    .faq-section {
      margin: 40px 0 60px;
    }

    .faq-item {
      margin-bottom: 20px;
      border-bottom: 1px solid #eee;
      padding-bottom: 20px;
    }

    .faq-question {
      font-weight: 600;
      color: #1a1a2e;
      margin-bottom: 10px;
      cursor: pointer;
      display: flex;
      justify-content: space-between;
      align-items: center;
    }

    .faq-answer {
      display: none;
      padding: 10px 0;
    }

    @media (max-width: 768px) {
      .hero-section {
        padding: 40px 0;
      }

      .hero-section h1 {
        font-size: 2rem;
      }

      .contact-grid {
        flex-direction: column;
      }

      .img-container {
        height: 250px;
        width: 340px;
      }
    }
  </style>

  <main class="contact-container">
    <section class="hero-section">
      <div class="container">
        <h1>Contact Voxera</h1>
        <p class="tagline">We're Here to Listen and Help</p>
      </div>
    </section>

    <section class="contact-content">
      <div class="pcontainer">
        <div class="contact-grid">
          <div class="contact-form">
            <h2>Send Us a Message</h2>
            <p>Have questions or feedback? Fill out the form below and our team will get back to you as soon as
              possible.</p>

            <form id="contactForm" action="/contact/submit" method="POST">
              <div class="form-group">
                <label for="name">Your Name</label>
                <input type="text" id="name" name="name" required>
              </div>

              <div class="form-group">
                <label for="email">Email Address</label>
                <input type="email" id="email" name="email" required>
              </div>

              <div class="form-group">
                <label for="subject">Subject</label>
                <input type="text" id="subject" name="subject" required>
              </div>

              <div class="form-group">
                <label for="message">Your Message</label>
                <textarea id="message" name="message" required></textarea>
              </div>

              <button type="submit">Send Message</button>
            </form>

            <div class="thank-you" id="thankYou">
              <div class="success-icon">
                <i class="fas fa-check-circle"></i>
              </div>
              <h3>Thank You!</h3>
              <p>Your message has been sent successfully. We'll get back to you shortly.</p>
            </div>
          </div>

          <div class="contact-info">
            <h2>Get in Touch</h2>

            <div class="contact-card">
              <div class="contact-details">
                <span class="contact-icon"><i class="fas fa-map-marker-alt"></i></span>
                <div>
                  <strong>Visit Us</strong>
                  <p>Sivaganga,TamilNadu</p>
                </div>
              </div>

              <div class="contact-details">
                <span class="contact-icon"><i class="fas fa-phone"></i></span>
                <div>
                  <strong>Call Us</strong>
                  <p>+91 7868831758</p>
                </div>
              </div>

              <div class="contact-details">
                <span class="contact-icon"><i class="fas fa-envelope"></i></span>
                <div>
                  <strong>Email Us</strong>
                  <p>praveenps20589@gmail.com</p>
                </div>
              </div>

              <div class="contact-details">
                <span class="contact-icon"><i class="fas fa-clock"></i></span>
                <div>
                  <strong>Hours</strong>
                  <p>Monday - Friday: 9:00 AM - 6:00 PM<br>Saturday: 10:00 AM - 4:00 PM</p>
                </div>
              </div>

              <div class="social-icons">
                <a href="#" class="social-icon"><i class="fab fa-facebook"></i></a>
                <a href="#" class="social-icon"><i class="fab fa-twitter"></i></a>
                <a href="#" class="social-icon"><i class="fab fa-instagram"></i></a>
                <a href="#" class="social-icon"><i class="fab fa-linkedin"></i></a>
              </div>
            </div>

            <div class="img-container">
            </div>
          </div>
        </div>

        <div class="faq-section">
          <h2>Frequently Asked Questions</h2>

          <div class="faq-item">
            <div class="faq-question">
              What is the warranty period for Voxera products?
              <i class="fas fa-chevron-down"></i>
            </div>
            <div class="faq-answer">
              <p>All Voxera products come with a standard 1-year warranty against manufacturing defects. Our premium
                line extends this coverage to 2 years. For specific details about your product's warranty, please check
                the documentation that came with your purchase or contact our support team.</p>
            </div>
          </div>

          <div class="faq-item">
            <div class="faq-question">
              How can I track my order?
              <i class="fas fa-chevron-down"></i>
            </div>
            <div class="faq-answer">
              <p>Once your order is shipped, you'll receive a confirmation email with tracking information. You can also
                log into your Voxera account and check the order status under "My Orders." If you have any issues
                tracking your package, please contact our customer service team.</p>
            </div>
          </div>

          <div class="faq-item">
            <div class="faq-question">
              What's your return policy?
              <i class="fas fa-chevron-down"></i>
            </div>
            <div class="faq-answer">
              <p>We offer a 30-day satisfaction guarantee on all purchases. If you're not completely satisfied with your
                Voxera product, you can return it in its original condition with all accessories and packaging for a
                full refund or exchange. Shipping costs for returns are the responsibility of the customer unless the
                product is defective.</p>
            </div>
          </div>

          <div class="faq-item">
            <div class="faq-question">
              Do you ship internationally?
              <i class="fas fa-chevron-down"></i>
            </div>
            <div class="faq-answer">
              <p>Yes, Voxera ships to most countries worldwide. International shipping rates and delivery times vary
                by location. During checkout, you'll see the shipping options available for your country. Please note
                that any import duties or taxes are the responsibility of the recipient.</p>
            </div>
          </div>
        </div>
      </div>
    </section>
  </main>

  <script>
    document.addEventListener('DOMContentLoaded', function () {
      // Form submission handling
      const contactForm = document.getElementById('contactForm');
      const thankYou = document.getElementById('thankYou');

      if (contactForm) {
        contactForm.addEventListener('submit', function (e) {
          e.preventDefault();
          // Here you would typically send the form data via AJAX
          // For demo purposes, we'll just show the thank you message
          contactForm.style.display = 'none';
          thankYou.style.display = 'block';
        });
      }

      // FAQ toggle functionality
      const faqQuestions = document.querySelectorAll('.faq-question');

      faqQuestions.forEach(question => {
        question.addEventListener('click', function () {
          const answer = this.nextElementSibling;
          const icon = this.querySelector('i');

          if (answer.style.display === 'block') {
            answer.style.display = 'none';
            icon.className = 'fas fa-chevron-down';
          } else {
            answer.style.display = 'block';
            icon.className = 'fas fa-chevron-up';
          }
        });
      });
    });
  </script>

  <%- include("../../views/partials/user/footers") %>
