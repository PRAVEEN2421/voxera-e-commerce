<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Voxera - Checkout</title>
    <link rel="icon" href="/img/icon.png" type="image/png" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/toastify-js/src/toastify.min.css">
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
            font-family: 'Poppins', sans-serif;
        }

        body {
            background-color: #f5f7fb;
            color: #2d3748;
            line-height: 1.6;
        }

        .container {
            max-width: 1100px;
            margin: 0 auto;
            padding: 30px 20px;
        }

        /* Checkout Header Styles */
        .checkout-header {
            margin-bottom: 40px;
            text-align: center;
        }

        .checkout-header h1 {
            font-size: 32px;
            font-weight: 700;
            margin-bottom: 15px;
            color: #303b5a;
            letter-spacing: -0.5px;
        }

        /* Progress Bar */
        .checkout-progress {
            position: relative;
            margin: 40px auto;
            max-width: 600px;
        }

        .progress-bar {
            position: relative;
            display: flex;
            justify-content: space-between;
            counter-reset: step;
        }

        .progress-bar::before {
            content: "";
            position: absolute;
            top: 20px;
            left: 0;
            width: 100%;
            height: 3px;
            background-color: #e2e8f0;
            z-index: 1;
        }

        .progress-bar::after {
            content: "";
            position: absolute;
            top: 20px;
            left: 0;
            width: 100%;
            height: 3px;
            background-color: #00f2ea;
            z-index: 1;
            transition: width 0.3s ease;
        }

        .step {
            position: relative;
            z-index: 2;
            text-align: center;
            width: 40px;
            height: 40px;
        }

        .step-icon {
            width: 40px;
            height: 40px;
            border-radius: 50%;
            background-color: #e2e8f0;
            color: #94a3b8;
            display: flex;
            align-items: center;
            justify-content: center;
            font-weight: 600;
            margin-bottom: 10px;
            transition: all 0.3s ease;
        }

        .step.active .step-icon {
            background-color: #00f2ea;
            color: #fff;
            box-shadow: 0 0 0 5px rgba(0, 242, 234, 0.2);
        }

        .step.completed .step-icon {
            background-color: #10b981;
            color: #fff;
        }

        .step-label {
            position: absolute;
            top: 45px;
            left: 50%;
            transform: translateX(-50%);
            font-size: 14px;
            font-weight: 500;
            white-space: nowrap;
            color: #94a3b8;
        }

        .step.active .step-label {
            color: #334155;
            font-weight: 600;
        }

        /* Checkout Content */
        .checkout-content {
            background-color: #fff;
            border-radius: 16px;
            box-shadow: 0 10px 30px rgba(0, 0, 0, 0.05);
            padding: 40px;
            margin-bottom: 30px;
            transition: all 0.3s ease;
        }

        .checkout-content:hover {
            box-shadow: 0 15px 40px rgba(0, 0, 0, 0.08);
        }

        .section-title {
            font-size: 24px;
            font-weight: 600;
            margin-bottom: 25px;
            color: #303b5a;
            display: flex;
            align-items: center;
        }

        .section-title svg {
            margin-right: 10px;
            color: #00f2ea;
        }

        /* Coupon Section */
        .coupon-section {
            background-color: #f8fafc;
            border-radius: 10px;
            padding: 20px;
            margin-bottom: 20px;
            border: 1px solid #e2e8f0;
        }

        .coupon-section h5 {
            font-size: 18px;
            margin-bottom: 15px;
            color: #334155;
        }

        .coupon-input-group {
            display: flex;
            gap: 10px;
            margin-bottom: 10px;
        }

        .coupon-input {
            flex: 1;
            padding: 10px 15px;
            border: 1px solid #e2e8f0;
            border-radius: 8px;
            font-size: 14px;
        }

        .coupon-btn {
            padding: 10px 20px;
            background-color: #00f2ea;
            color: #0c4a47;
            border: none;
            border-radius: 8px;
            font-weight: 500;
            cursor: pointer;
            transition: all 0.3s ease;
        }

        .coupon-btn:hover {
            background-color: #00dad3;
        }

        .coupon-message {
            font-size: 14px;
            margin-top: 8px;
        }

        .coupon-success {
            color: #10b981;
        }

        .coupon-error {
            color: #ef4444;
        }

        .coupon-applied {
            background-color: #f0fdf4;
            border: 1px solid #bbf7d0;
            border-radius: 8px;
            padding: 15px;
            margin-top: 15px;
            display: flex;
            justify-content: space-between;
            align-items: center;
        }

        .coupon-applied strong {
            color: #10b981;
        }

        .remove-coupon {
            background-color: #fee2e2;
            color: #b91c1c;
            border: none;
            border-radius: 6px;
            padding: 5px 10px;
            font-size: 13px;
            cursor: pointer;
            transition: all 0.3s ease;
        }

        .remove-coupon:hover {
            background-color: #fecaca;
        }

        /* Order Details */
        .order-summary {
            margin-bottom: 30px;
        }

        .order-section {
            margin-bottom: 30px;
        }

        .order-section h3.section-title {
            font-size: 18px;
            margin-bottom: 15px;
            color: #475569;
            display: flex;
            align-items: center;
        }

        /* Address Display Styles */
        .address-display {
            background-color: #f8fafc;
            border-radius: 10px;
            padding: 15px 20px;
            border: 1px solid #e2e8f0;
            margin-bottom: 20px;
        }

        .address-display p {
            margin-bottom: 5px;
            color: #475569;
            font-size: 15px;
        }

        /* Payment Display */
        .payment-display {
            background-color: #f8fafc;
            border-radius: 10px;
            padding: 15px 20px;
            border: 1px solid #e2e8f0;
            margin-bottom: 20px;
        }

        .payment-display p {
            margin-bottom: 5px;
            color: #475569;
            font-size: 15px;
        }

        .payment-method {
            font-weight: 600;
            color: #00f2ea;
        }

        /* Order Items */
        .order-items {
            border: 1px solid #e2e8f0;
            border-radius: 10px;
            overflow: hidden;
            margin-bottom: 20px;
        }

        .order-item {
            display: flex;
            padding: 15px;
            border-bottom: 1px solid #e2e8f0;
        }

        .order-item:last-child {
            border-bottom: none;
        }

        .item-image {
            width: 60px;
            height: 60px;
            margin-right: 15px;
            border-radius: 8px;
            object-fit: cover;
            background-color: #f1f5f9;
        }

        .item-details {
            flex: 1;
        }

        .item-name {
            font-weight: 600;
            color: #334155;
            margin-bottom: 5px;
            font-size: 15px;
        }

        .item-price {
            color: #00f2ea;
            font-weight: 600;
            font-size: 14px;
        }

        .item-quantity {
            color: #64748b;
            font-size: 14px;
        }

        /* Order Totals */
        .order-totals {
            background-color: #f8fafc;
            border-radius: 10px;
            padding: 20px;
            border: 1px solid #e2e8f0;
        }

        .total-row {
            display: flex;
            justify-content: space-between;
            margin-bottom: 12px;
            color: #475569;
            font-size: 15px;
        }

        .discount-row {
            color: #10b981;
        }

        .total-row:last-child {
            margin-bottom: 0;
            padding-top: 12px;
            border-top: 1px solid #e2e8f0;
            font-weight: 600;
            font-size: 18px;
            color: #303b5a;
        }

        /* Delivery Information */
        .delivery-info {
            background-color: #f0fdfa;
            border-radius: 10px;
            padding: 15px 20px;
            border: 1px solid #ccfbf1;
            margin-bottom: 20px;
            position: relative;
            overflow: hidden;
        }

        .delivery-info::before {
            content: "";
            position: absolute;
            top: 0;
            left: 0;
            width: 4px;
            height: 100%;
            background-color: #10b981;
        }

        .delivery-info p {
            margin-bottom: 5px;
            color: #0f766e;
            font-size: 15px;
        }

        /* Action Buttons */
        .checkout-actions {
            display: flex;
            justify-content: center;
            align-items: center;
            margin-top: 30px;
            padding-top: 20px;
            border-top: 1px solid #e2e8f0;
        }

        .btn {
            padding: 12px 24px;
            border-radius: 10px;
            font-size: 16px;
            font-weight: 500;
            cursor: pointer;
            transition: all 0.3s ease;
            border: none;
            outline: none;
            text-decoration: none;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            min-width: 150px;
        }

        .btn svg {
            margin-right: 8px;
        }

        .btn-primary {
            background-color: #00f2ea;
            color: #0c4a47;
            box-shadow: 0 4px 15px rgba(0, 242, 234, 0.2);
        }

        .btn-primary:hover {
            background-color: #00dad3;
            transform: translateY(-2px);
            box-shadow: 0 8px 20px rgba(0, 242, 234, 0.25);
        }

        /* Loading Spinner */
        .spinner {
            display: inline-block;
            width: 20px;
            height: 20px;
            border: 3px solid rgba(255, 255, 255, .3);
            border-radius: 50%;
            border-top-color: #fff;
            animation: spin 1s ease-in-out infinite;
            margin-right: 8px;
        }

        @keyframes spin {
            to {
                transform: rotate(360deg);
            }
        }

        /* Responsive styles */
        @media (max-width: 768px) {
            .container {
                padding: 20px 15px;
            }

            .checkout-content {
                padding: 25px;
            }

            .checkout-progress {
                max-width: 100%;
            }

            .step-label {
                font-size: 12px;
            }

            .coupon-input-group {
                flex-direction: column;
            }

            .coupon-btn {
                width: 100%;
            }

            .checkout-actions {
                flex-direction: column;
                gap: 15px;
            }

            .checkout-actions .btn {
                width: 100%;
            }
        }
    </style>
</head>

<body>
    <div class="container">
        <div class="checkout-header">
            <h1>Checkout</h1>

            <div class="checkout-progress">
                <div class="progress-bar">
                    <div class="step completed">
                        <div class="step-icon">
                            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24"
                                fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"
                                stroke-linejoin="round">
                                <polyline points="20 6 9 17 4 12"></polyline>
                            </svg>
                        </div>
                        <div class="step-label">Shipping</div>
                    </div>
                    <div class="step completed">
                        <div class="step-icon">
                            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24"
                                fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"
                                stroke-linejoin="round">
                                <polyline points="20 6 9 17 4 12"></polyline>
                            </svg>
                        </div>
                        <div class="step-label">Payment</div>
                    </div>
                    <div class="step active">
                        <div class="step-icon">3</div>
                        <div class="step-label">Confirmation</div>
                    </div>
                </div>
            </div>
        </div>

        <div class="checkout-content">
            <h1 class="section-title">
                <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none"
                    stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <circle cx="8" cy="21" r="1"></circle>
                    <circle cx="19" cy="21" r="1"></circle>
                    <path d="M2.05 2.05h2l2.66 12.42a2 2 0 0 0 2 1.58h9.78a2 2 0 0 0 1.95-1.57l1.65-7.43H5.12"></path>
                </svg>
                Order Details
            </h1>

            <!-- Order Summary Section -->
            <div class="order-summary">
                <!-- Coupon Section -->
                <div class="coupon-section">
                    <h5>Apply Coupon Code</h5>
                    <% if (!coupon) { %>
                        <div class="coupon-input-group">
                            <input type="text" id="couponCode" class="coupon-input" placeholder="Enter coupon code">
                            <button id="applyCouponBtn" class="coupon-btn">Apply</button>
                        </div>
                        <div id="couponMessage" class="coupon-message"></div>
                        <% } else { %>
                            <div class="coupon-applied">
                                <div>
                                    <strong>Coupon Applied:</strong>
                                    <%= coupon.code %> (<%= coupon.percentage %>% off)
                                            <div>You saved: ₹<%= priceDetails.couponDiscount.toFixed(2) %>
                                            </div>
                                </div>
                                <button id="removeCouponBtn" class="remove-coupon">Remove</button>
                            </div>
                            <% } %>
                </div>

                <!-- Delivery Information -->
                <div class="order-section">
                    <h1 class="section-title">
                        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none"
                            stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                            <circle cx="12" cy="12" r="10"></circle>
                            <polyline points="12 6 12 12 16 14"></polyline>
                        </svg>
                        Delivery Information
                    </h1>
                </div>

                <!-- Shipping Address -->
                <div class="order-section">
                    <h3 class="section-title">
                        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none"
                            stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                            <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"></path>
                            <circle cx="12" cy="10" r="3"></circle>
                        </svg>
                        Shipping Address
                    </h3>
                    <div class="address-display">
                        <p><strong>Name:</strong>
                            <%= name %>
                        </p>
                        <p><strong>Phone:</strong>
                            <%= phone %>
                        </p>
                        <p>
                            <%= address.doorNo %>, <%= address.street %>
                        </p>
                        <p>
                            <%= address.city %>, <%= address.district %>
                        </p>
                        <p>
                            <%= address.pinCode %>
                        </p>
                    </div>
                </div>

                <!-- Payment Method -->
                <div class="order-section">
                    <h3 class="section-title">
                        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none"
                            stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                            <rect x="1" y="4" width="22" height="16" rx="2" ry="2"></rect>
                            <line x1="1" y1="10" x2="23" y2="10"></line>
                        </svg>
                        Payment Method
                    </h3>
                    <div class="payment-display">
                        <p class="payment-method">
                            <%= paymentMethod %>
                        </p>
                        <% if (paymentMethod==='Cash on delivery' ) { %>
                            <p>Pay with cash when your order is delivered to your doorstep.</p>
                            <% } else { %>
                                <p>Pay securely with Razorpay</p>
                                <% } %>
                    </div>
                </div>

                <!-- Order Items -->
                <div class="order-section">
                    <h3 class="section-title">
                        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none"
                            stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                            <line x1="16.5" y1="9.4" x2="7.5" y2="4.21"></line>
                            <path
                                d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z">
                            </path>
                            <polyline points="3.29 7 12 12 20.71 7"></polyline>
                            <line x1="12" y1="22" x2="12" y2="12"></line>
                        </svg>
                        Order Items
                    </h3>
                    <div class="order-items">
                        <% cartItems.forEach(item=> { %>
                            <div class="order-item">
                                <img src="<%= item.productId.productImage1 %>" alt="<%= item.productId.productName %>"
                                    class="item-image">
                                <div class="item-details">
                                    <div class="item-name">
                                        <%= item.productId.productName %>
                                    </div>
                                    <div class="item-price">₹<%= item.productId.productOfferPrice ||
                                            item.productId.productPrice %>
                                    </div>
                                    <div class="item-quantity">Quantity: <%= item.productQuantity %>
                                    </div>
                                </div>
                            </div>
                            <% }); %>
                    </div>
                </div>

                <!-- Order Total -->
                <div class="order-section">
                    <h3 class="section-title">
                        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none"
                            stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                            <line x1="12" y1="1" x2="12" y2="23"></line>
                            <path d="M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"></path>
                        </svg>
                        Order Total
                    </h3>
                    <div class="order-totals">
                        <div class="total-row">
                            <span>Subtotal:</span>
                            <span>₹<%= priceDetails.subtotal.toFixed(2) %></span>
                        </div>
                        <% if (priceDetails.couponDiscount> 0) { %>
                            <div class="total-row discount-row">
                                <span>Coupon Discount:</span>
                                <span>-₹<%= priceDetails.couponDiscount.toFixed(2) %></span>
                            </div>
                            <% } %>
                                <div class="total-row">
                                    <span>Tax (18%):</span>
                                    <span>₹<%= priceDetails.tax.toFixed(2) %></span>
                                </div>
                                <div class="total-row">
                                    <span>Total:</span>
                                    <span>₹<%= priceDetails.total.toFixed(2) %></span>
                                </div>
                    </div>
                </div>
            </div>

            <div class="checkout-actions">
                <button id="confirmOrderBtn" class="btn btn-primary">
                    <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none"
                        stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <polyline points="20 6 9 17 4 12"></polyline>
                    </svg>
                    Confirm Order
                </button>
            </div>
        </div>
    </div>
    <%- include("../../views/partials/user/footers") %>

        <!-- Toast Notification JS -->
        <script src="https://cdn.jsdelivr.net/npm/toastify-js"></script>
        <script src="https://checkout.razorpay.com/v1/checkout.js"></script>
        <script>
            document.addEventListener("DOMContentLoaded", function () {
                const checkoutBtn = document.getElementById('confirmOrderBtn');
                const cartItems = JSON.parse('<%- JSON.stringify(cartItems) %>');

                if (cartItems.length === 0) {
                    checkoutBtn.disabled = true;
                    checkoutBtn.style.opacity = "0.5";
                    checkoutBtn.style.cursor = "not-allowed";
                }

                // Coupon Application
                const applyCouponBtn = document.getElementById('applyCouponBtn');
                if (applyCouponBtn) {
                    applyCouponBtn.addEventListener('click', async function () {
                        const couponCode = document.getElementById('couponCode').value.trim();
                        const couponMessage = document.getElementById('couponMessage');

                        if (!couponCode) {
                            couponMessage.textContent = "Please enter a coupon code";
                            couponMessage.className = "coupon-message coupon-error";
                            return;
                        }

                        try {
                            const response = await fetch('/apply-coupon', {
                                method: 'POST',
                                headers: {
                                    'Content-Type': 'application/json',
                                },
                                body: JSON.stringify({ couponCode })
                            });

                            const data = await response.json();

                            if (data.success) {
                                Toastify({
                                    text: "Coupon applied successfully!",
                                    duration: 2000,
                                    className: "custom-toast",
                                    close: true,
                                    gravity: "top",
                                    position: "right",
                                    style: {
                                        background: "#10b981",
                                    }
                                }).showToast();

                                setTimeout(() => {
                                    location.reload();
                                }, 1500);
                            } else {
                                couponMessage.textContent = data.message;
                                couponMessage.className = "coupon-message coupon-error";
                            }
                        } catch (error) {
                            console.error('Error applying coupon:', error);
                            couponMessage.textContent = "Failed to apply coupon";
                            couponMessage.className = "coupon-message coupon-error";
                        }
                    });
                }

                // Coupon Removal
                const removeCouponBtn = document.getElementById('removeCouponBtn');
                if (removeCouponBtn) {
                    removeCouponBtn.addEventListener('click', async function () {
                        try {
                            const response = await fetch('/remove-coupon', {
                                method: 'POST',
                                headers: {
                                    'Content-Type': 'application/json',
                                }
                            });

                            const data = await response.json();

                            if (data.success) {
                                Toastify({
                                    text: "Coupon removed successfully",
                                    duration: 2000,
                                    className: "custom-toast",
                                    close: true,
                                    gravity: "top",
                                    position: "right",
                                    style: {
                                        background: "#3b82f6",
                                    }
                                }).showToast();

                                setTimeout(() => {
                                    location.reload();
                                }, 1500);
                            }
                        } catch (error) {
                            console.error('Error removing coupon:', error);
                            showError("Failed to remove coupon");
                        }
                    });
                }

                // Order Confirmation
                checkoutBtn.addEventListener('click', handlePayment);

                async function handlePayment() {
                    try {
                        const paymentMethod = '<%= paymentMethod %>';
                        const originalBtnText = checkoutBtn.innerHTML;

                        // Show loading state
                        checkoutBtn.disabled = true;
                        checkoutBtn.innerHTML = `<span class="spinner"></span> Processing...`;

                        if (paymentMethod === 'Cash on delivery' || paymentMethod === 'Wallet') {
                            
                            const response = await fetch('/place-order', {
                                method: 'POST',
                                headers: {
                                    'Content-Type': 'application/json',
                                }
                            });

                            if (response.ok) {
                                showSuccess("Order confirmed successfully!");
                                setTimeout(() => {
                                    window.location.href = '/order-confirmation';
                                }, 1500);
                            } else {
                                const result = await response.json();
                                throw new Error(result.message || 'Failed to confirm order');
                            }
                        } else {
                            // For Razorpay payment
                         const amount = priceDetails.total;

                            //  Create order on your server
                            const orderResponse = await fetch('/create-razorpay-order', {
                                method: 'POST',
                                headers: {
                                    'Content-Type': 'application/json',
                                },
                                body: JSON.stringify({ amount })
                            });

                            const { order: razorpayOrder } = await orderResponse.json();

                            // Open Razorpay checkout
                            const options = {
                                key: '<%= razorpayKey %>',
                                amount: razorpayOrder.amount,
                                currency: 'INR',
                                name: 'Voxera',
                                description: 'Order Payment',
                                order_id: razorpayOrder.id,
                                handler: async function (response) {
                                    try {
                                        // Verify payment on your server
                                        const verification = await fetch('/verify-payment', {
                                            method: 'POST',
                                            headers: {
                                                'Content-Type': 'application/json',
                                            },
                                            body: JSON.stringify(response)
                                        });

                                        const result = await verification.json();

                                        if (result.success) {
                                            // Submit the order
                                            const orderResponse = await fetch('/place-order', {
                                                method: 'POST',
                                                headers: {
                                                    'Content-Type': 'application/json',
                                                }
                                            });

                                            if (orderResponse.ok) {
                                                window.location.href = '/order-confirmation';
                                            } else {
                                                throw new Error('Order placement failed');
                                            }
                                        } else {
                                            throw new Error('Payment verification failed');
                                        }
                                    } catch (error) {
                                        console.error('Payment processing error:', error);
                                        showError(error.message);
                                        checkoutBtn.disabled = false;
                                        checkoutBtn.innerHTML = originalBtnText;
                                    }
                                },
                                prefill: {
                                    name: '<%= user.name %>',
                                    email: '<%= user.email %>',
                                    contact: '<%= user.phone %>'
                                },
                                theme: {
                                    color: '#00f2ea'
                                }
                            };

                            const rzp = new Razorpay(options);
                            rzp.open();

                            rzp.on('payment.failed', async function (response) {
                                try {
                                    // Show loading state
                                    checkoutBtn.disabled = true;
                                    checkoutBtn.innerHTML = `<span class="spinner"></span> Processing...`;

                                    // Call the failed order endpoint
                                    const orderResponse = await fetch('/place-failed-order', {
                                        method: 'POST',
                                        headers: {
                                            'Content-Type': 'application/json',
                                        },
                                        body: JSON.stringify({
                                            paymentDetails: response.error // Include Razorpay error details
                                        })
                                    });

                                    const orderResult = await orderResponse.json();

                                    if (orderResult.success) {
                                        // Redirect to payment failed page
                                        window.location.href = '/payment-failed';
                                    } else {
                                        throw new Error('Failed to save your order');
                                    }
                                } catch (error) {
                                    console.error('Payment failure handling error:', error);
                                    showError(error.message || 'Failed to process your payment');
                                } finally {
                                    checkoutBtn.disabled = false;
                                    checkoutBtn.innerHTML = originalBtnText;
                                }
                            });
                        }
                    } catch (error) {
                        console.error('Checkout error:', error);
                        showError(error.message || 'Payment processing failed');
                        checkoutBtn.disabled = false;
                        checkoutBtn.innerHTML = originalBtnText;
                    }
                }

                function showError(message) {
                    Toastify({
                        text: message,
                        duration: 3000,
                        className: "custom-toast",
                        close: true,
                        gravity: "top",
                        position: "right",
                        style: {
                            background: "#ef4444",
                        }
                    }).showToast();
                }

                function showSuccess(message) {
                    Toastify({
                        text: message,
                        duration: 3000,
                        className: "custom-toast",
                        close: true,
                        gravity: "top",
                        position: "right",
                        style: {
                            background: "#10b981",
                        }
                    }).showToast();
                }
            });
        </script>
</body>

</html>