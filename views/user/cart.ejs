                                            data-max="<%= item.productId.productStock %>">+</button>
                                    </div>
                                </div>
                                <div class="col-4 col-md-2 mt-3 mt-md-0 text-end">
                                    <p class="item-total">₹<%= (item.productId.productOfferPrice *
                                            item.productQuantity).toFixed(2) %>
                                    </p>
                                </div>
                                <div class="col-2 col-md-1 mt-3 mt-md-0 text-end">
                                    <button class="remove-btn" data-id="<%= item._id %>">
                                        <i class="fas fa-trash"></i>
                                    </button>
                                </div>
                        </div>
                        <% }); %>
                    </div>

                    <div class="col-lg-4">
                        <div class="summary-card">
                            <h5 class="summary-title">Order Summary</h5>
                            <div class="summary-row">
                                <span>Subtotal</span>
                                <span>₹<%= subtotal.toFixed(2) %></span>
                            </div>
                            <div class="summary-row">
                                <span>Shipping</span>
                                <span>Free</span>
                            </div>
                            <div class="summary-row">
                                <span>Tax</span>
                                <span>18%</span>
                            </div>
                            <div class="summary-divider"></div>
                            <div class="summary-total">
                                <span>Total</span>
                                <span id="summary-total">₹<%= total.toFixed(2) %></span>
                            </div>
                            <a href="/checkout" class="btn checkout-btn">Proceed to Checkout</a>
                        </div>
                    </div>
            </div>
            <% } else { %>
                <div class="empty-cart">
                    <div class="empty-cart-icon">
                        <i class="fas fa-shopping-cart"></i>
                    </div>
                    <h3>Your cart is empty</h3>
                    <p>Looks like you haven't added anything to your cart yet</p>
                    <a href="/shop" class="btn">Start Shopping</a>
                </div>
                <% } %>
        </div>
        </div>

