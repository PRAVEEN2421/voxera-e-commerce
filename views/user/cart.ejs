                                    <div class="col-6 col-md-3 mt-3 mt-md-0">
                                    <div class="quantity-control">
                                        <button class="quantity-btn decrease" data-id="<%= item._id %>">-</button>
                                        <input type="number" class="quantity-input" value="<%= item.productQuantity %>"
