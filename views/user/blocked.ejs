<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Access Denied</title>
  <link rel="icon" href="/images/logo.png">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;600;700&display=swap" rel="stylesheet">
  <style>
    body {
      font-family: 'Poppins', sans-serif;
      margin: 0;
      padding: 0;
      background-color: #121212;
      display: flex;
      justify-content: center;
      align-items: center;
      height: 100vh;
      overflow: hidden;
      position: relative;
    }

    .background-grid {
      position: absolute;
      width: 200%;
      height: 200%;
      background-image: 
        linear-gradient(transparent 95%, #00FFFB 96%, transparent 96%),
        linear-gradient(90deg, transparent 95%, #00FFFB 96%, transparent 96%);
      background-size: 40px 40px;
      opacity: 0.15;
      transform: perspective(500px) rotateX(60deg);
      animation: grid-move 20s linear infinite;
    }

    @keyframes grid-move {
      0% { transform: perspective(500px) rotateX(60deg) translateY(0); }
      100% { transform: perspective(500px) rotateX(60deg) translateY(40px); }
    }

    .blocked-container {
      position: relative;
      z-index: 10;
      text-align: center;
      padding: 40px;
      border-radius: 10px;
      background-color: rgba(18, 18, 18, 0.85);
      box-shadow: 0 0 30px #00FFFB, 0 0 15px rgba(0, 255, 251, 0.5) inset;
      backdrop-filter: blur(5px);
      max-width: 450px;
      border: 1px solid rgba(0, 255, 251, 0.3);
    }

    .glow {
      position: absolute;
      width: 150px;
      height: 150px;
      background: radial-gradient(circle, rgba(0, 255, 251, 0.5) 0%, rgba(0, 255, 251, 0) 70%);
      border-radius: 50%;
      pointer-events: none;
      opacity: 0.5;
      animation: pulse 3s ease-in-out infinite alternate;
    }

    @keyframes pulse {
      0% { transform: scale(1); opacity: 0.3; }
      100% { transform: scale(1.3); opacity: 0.6; }
    }

    .blocked-icon {
      position: relative;
      font-size: 70px;
      color: #00FFFB;
      margin-bottom: 25px;
      text-shadow: 0 0 15px rgba(0, 255, 251, 0.7);
    }

    .blocked-icon::before {
      content: '🔒';
      position: absolute;
      top: 0;
      left: 50%;
      transform: translateX(-50%);
      animation: shake 3s ease-in-out infinite;
    }

    @keyframes shake {
      0%, 100% { transform: translateX(-50%) rotate(0); }
      10%, 30%, 50%, 70%, 90% { transform: translateX(-55%) rotate(-10deg); }
      20%, 40%, 60%, 80% { transform: translateX(-45%) rotate(10deg); }
    }

    .blocked-message {
      font-size: 28px;
      font-weight: 700;
      color: #ffffff;
      margin-bottom: 15px;
      text-shadow: 0 0 10px rgba(0, 255, 251, 0.8);
      letter-spacing: 1px;
    }

    .help-text {
      font-size: 16px;
      color: #cccccc;
      margin-bottom: 30px;
      line-height: 1.5;
    }

    .button-container {
      display: flex;
      gap: 25px;
      justify-content: center;
      margin-top: 20px;
    }

    .contact-button, .logout-button {
      display: inline-block;
      padding: 14px 28px;
      font-size: 16px;
      font-weight: 600;
      color: #121212;
      border: none;
      border-radius: 50px;
      text-decoration: none;
      cursor: pointer;
      transition: all 0.3s cubic-bezier(0.25, 0.8, 0.25, 1);
      position: relative;
      overflow: hidden;
    }

    .contact-button::before, .logout-button::before {
      content: '';
      position: absolute;
      top: 0;
      left: -100%;
      width: 100%;
      height: 100%;
      background: rgba(255, 255, 255, 0.2);
      transition: all 0.4s ease;
    }

    .contact-button:hover::before, .logout-button:hover::before {
      left: 100%;
    }

    .contact-button {
      background-color: #00FFFB;
      box-shadow: 0 4px 15px rgba(0, 255, 251, 0.5);
    }

    .contact-button:hover {
      background-color: #00DAD8;
      transform: translateY(-5px);
      box-shadow: 0 7px 20px rgba(0, 255, 251, 0.6);
    }

    .logout-button {
      background-color: #FF4949;
      box-shadow: 0 4px 15px rgba(255, 73, 73, 0.5);
    }

    .logout-button:hover {
      background-color: #E63535;
      transform: translateY(-5px);
      box-shadow: 0 7px 20px rgba(255, 73, 73, 0.6);
    }

    .footer-note {
      margin-top: 30px;
      font-size: 14px;
      color: #888888;
      font-style: italic;
    }

    .circle {
      position: absolute;
      border-radius: 50%;
      background-color: rgba(0, 255, 251, 0.1);
      filter: blur(3px);
      z-index: -1;
    }

    .circle:nth-child(1) {
      width: 250px;
      height: 250px;
      top: -120px;
      right: -80px;
    }

    .circle:nth-child(2) {
      width: 150px;
      height: 150px;
      bottom: -70px;
      left: -50px;
      background-color: rgba(0, 255, 251, 0.15);
    }
  </style>
</head>
<body>
  <div class="background-grid"></div>
  <div class="glow"></div>
  
  <div class="blocked-container">
    <div class="circle"></div>
    <div class="circle"></div>
    
    <div class="blocked-icon"></div>
    <div class="blocked-message">Access Denied</div>
    <div class="help-text">Your access has been temporarily restricted. Please contact our support team to resolve this issue and regain access to your account.</div>
    
    <div class="button-container">
      <a href="https://mail.google.com/mail/?view=cm&fs=1&to=Voxera123@gmail.com" class="contact-button">Contact Support</a>
      <form action="/logout" method="post"><button type="submit" class="logout-button">Sign Out</button></form>
    </div>
    
    <div class="footer-note">Our team is available 24/7 to assist you with any issues.</div>
  </div>

  <script>
    // Follow mouse movement for the glow effect
    const glow = document.querySelector('.glow');
    document.addEventListener('mousemove', (e) => {
      const x = e.clientX;
      const y = e.clientY;
      glow.style.left = `${x - 75}px`;
      glow.style.top = `${y - 75}px`;
    });
  </script>
</body>
</html>