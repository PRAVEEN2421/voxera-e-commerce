<%- include("../../views/partials/user/headers") %>
    <style>
        :root {
            --primary-color: #00f2ea;
            --primary-dark: #00d6d0;
            --text-dark: #333;
            --text-light: #666;
            --border-color: #eee;
            --bg-light: #fafafa;
            --bg-white: #ffffff;
            --shadow: 0 4px 12px rgba(0, 0, 0, 0.05);
            --radius: 12px;
            --radius-sm: 8px;
            --spacing-sm: 10px;
            --spacing-md: 20px;
            --spacing-lg: 30px;
            --danger-color: #ff5252;
            --danger-dark: #d32f2f;
            --success-color: #28a745;
            --warning-color: #ffc107;
            --warning-dark: #e0a800;
        }

        * {
            box-sizing: border-box;
            margin: 0;
            padding: 0;
        }

        body {
            font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Oxygen, Ubuntu, Cantarell, 'Open Sans', 'Helvetica Neue', sans-serif;
            background-color: var(--bg-light);
            color: var(--text-dark);
            line-height: 1.6;
        }

        .page-content {
            width: 100%;
            max-width: 1200px;
            margin: 0 auto;
            padding: 20px;
        }

        .back-button {
            display: inline-flex;
            align-items: center;
            margin-bottom: 20px;
            color: var(--text-dark);
            text-decoration: none;
            font-weight: 500;
            transition: all 0.2s ease;
        }

        .back-button:hover {
            color: var(--primary-color);
        }

        .back-button svg {
            margin-right: 8px;
        }

        .order-details-container {
            background-color: var(--bg-white);
            border-radius: var(--radius);
            box-shadow: var(--shadow);
            padding: 30px;
            margin-bottom: 30px;
        }

        .order-header {
            display: flex;
            justify-content: space-between;
            align-items: flex-start;
            margin-bottom: 30px;
            flex-wrap: wrap;
            gap: 20px;
        }

        .order-title {
            font-size: 24px;
            font-weight: 700;
            margin-bottom: 8px;
        }

        .order-id {
            font-size: 16px;
            color: var(--text-light);
            margin-bottom: 4px;
        }

        .order-date {
            font-size: 14px;
            color: var(--text-light);
        }

        .order-status {
            padding: 6px 14px;
            border-radius: 20px;
            font-size: 14px;
            font-weight: 500;
            display: inline-block;
        }

        .status-pending {
            background-color: #fff8e1;
            color: #ff8f00;
        }

        .status-processing {
            background-color: #fff4e5;
            color: #ff8800;
        }

        .status-shipped {
            background-color: #e6f6ff;
            color: #0085ff;
        }

        .status-delivered {
            background-color: #e3f9e5;
            color: #1b873d;
        }

        .status-cancelled {
            background-color: #ffebee;
            color: #d32f2f;
        }

        .info-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
            gap: 30px;
            margin-bottom: 30px;
        }

        .info-card {
            box-shadow: rgba(50, 50, 93, 0.25) 0px 50px 100px -20px, rgba(0, 0, 0, 0.3) 0px 30px 60px -30px, rgba(10, 37, 64, 0.35) 0px -2px 6px 0px inset;
            border-radius: var(--radius-sm);
            padding: 20px;
            background: #FFFF;
            background: radial-gradient(circle, rgba(255, 255, 255, 1) 0%, rgba(187, 253, 252, 0.72) 100%);
        }

        .info-title {
            font-size: 16px;
            font-weight: 600;
            margin-bottom: 15px;
            display: flex;
            align-items: center;
        }

        .info-title svg {
            margin-right: 8px;
        }

        .info-content {
            font-size: 14px;
            color: var(--text-dark);
        }

        .info-content p {
            margin-bottom: 6px;
        }

        .info-content p:last-child {
            margin-bottom: 0;
        }

        .product-table {
            width: 100%;
            border-collapse: collapse;
            margin-bottom: 30px;
        }

        .product-table th,
        .product-table td {
            padding: 15px;
            text-align: left;
            border-bottom: 1px solid var(--border-color);
        }

        .product-table th {
            font-weight: 600;
            color: var(--text-light);
            font-size: 14px;
            text-transform: uppercase;
            letter-spacing: 0.5px;
        }

        .product-table tr:last-child td {
            border-bottom: none;
        }

        .product-image {
            width: 60px;
            height: 60px;
            object-fit: cover;
            border-radius: var(--radius-sm);
            background-color: #f5f5f5;
        }

        .product-name {
            font-weight: 500;
        }

        .summary-section {
            display: flex;
            justify-content: flex-end;
            margin-bottom: 30px;
        }

        .order-summary {
            width: 100%;
            max-width: 400px;
        }

        .summary-row {
            display: flex;
            justify-content: space-between;
            padding: 10px 0;
            border-bottom: 1px solid var(--border-color);
        }

        .summary-row:last-child {
            border-bottom: none;
            font-weight: 700;
            font-size: 18px;
            padding-top: 15px;
        }

        .action-buttons {
            display: flex;
            gap: 15px;
            flex-wrap: wrap;
        }

        .button {
            display: inline-flex;
            align-items: center;
            justify-content: center;
            padding: 12px 24px;
            border-radius: var(--radius-sm);
            font-size: 16px;
            font-weight: 500;
            text-decoration: none;
            cursor: pointer;
            transition: all 0.2s ease;
            border: none;
            outline: none;
            box-shadow: rgba(13, 13, 21, 0.25) 0px 50px 100px -20px, rgba(0, 0, 0, 0.3) 0px 30px 60px -30px, rgba(10, 37, 64, 0.35) 0px -2px 6px 0px inset;
        }

        .repay {
            display: inline-flex;
            align-items: center;
            justify-content: center;
            padding: 12px 24px;
            border-radius: var(--radius-sm);
            font-size: 16px;
            font-weight: 500;
            text-decoration: none;
            cursor: pointer;
            outline: none;
            transition: all 0.2s ease;
            border: none;
            box-shadow: rgba(13, 13, 21, 0.25) 0px 50px 100px -20px, rgba(0, 0, 0, 0.3) 0px 30px 60px -30px, rgba(10, 37, 64, 0.35) 0px -2px 6px 0px inset;
        }

        .repay:hover {
            background-color: #00FFFB;
            border: none;
            outline: none;
        }

        .button svg {
            margin-right: 8px;
        }

        .primary-button {
            background-color: var(--primary-color);
            color: #000;
        }

        .primary-button:hover {
            background-color: var(--primary-dark);
            transform: translateY(-2px);
            box-shadow: 0 4px 8px rgba(0, 0, 0, 0.1);
        }

        .danger-button {
            background-color: var(--danger-color);
            color: white;
        }

        .danger-button:hover {
            background-color: var(--danger-dark);
            transform: translateY(-2px);
            box-shadow: 0 4px 8px rgba(0, 0, 0, 0.1);
        }

        .outline-button {
            background-color: transparent;
            border: 1px solid var(--border-color);
            color: var(--text-dark);
            border: none;
        }

        .outline-button:hover {
            background-color: var(--bg-light);
            border-color: var(--text-light);
        }

        a {
            text-decoration: none !important;
        }

        .spinner {
            display: inline-block;
            width: 1rem;
            height: 1rem;
            border: 2px solid rgba(255, 255, 255, 0.3);
            border-radius: 50%;
            border-top-color: #fff;
            animation: spin 1s ease-in-out infinite;
            margin-right: 0.5rem;
        }

        @keyframes spin {
            to {
                transform: rotate(360deg);
            }
        }

        /* Responsive styles */
        @media (max-width: 768px) {
            .order-header {
                flex-direction: column;
                align-items: flex-start;
                gap: 15px;
            }

            .product-table {
                display: block;
                overflow-x: auto;
            }

            .action-buttons {
                flex-direction: column;
                width: 100%;
            }

            .button {
                width: 100%;
            }
        }
    </style>

    <!-- Add SweetAlert2 CDN -->
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

    <body>
        <div class="page-content">
            <a href="/orders" class="back-button">
                <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none"
                    stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <line x1="19" y1="12" x2="5" y2="12"></line>
                    <polyline points="12 19 5 12 12 5"></polyline>
                </svg>
                Back to Orders
            </a>

            <div class="order-details-container">
                <div class="order-header">
                    <div>
                        <h1 class="order-title">Order Details</h1>
                        <p class="order-id">Order ID: #<%= orderData.orderId %>
                        </p>
                        <p class="order-date">Placed on: <%= new Date(orderData.createdAt).toLocaleDateString() %>
                        </p>
                    </div>
                    <div class="order-status-container">

                        <span class="order-status status-<%= orderData.status.toLowerCase() %>">
                            <%= orderData.status %>
                        </span>

                    </div>
                </div>

                <div class="info-grid">
                    <div class="info-card">
                        <h3 class="info-title">
                            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24"
                                fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"
                                stroke-linejoin="round">
                                <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"></path>
                                <circle cx="12" cy="7" r="4"></circle>
                            </svg>
                            Customer Information
                        </h3>
                        <div class="info-content">
                            <p><strong>Name:</strong>
                                <%= orderData.fullName %>
                            </p>
                            <p><strong>Email:</strong>
                                <%= orderData.email %>
                            </p>
                            <p><strong>Phone:</strong>
                                <%= orderData.phone %>
                            </p>
                        </div>
                    </div>

                    <div class="info-card">
                        <h3 class="info-title">
                            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24"
                                fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"
                                stroke-linejoin="round">
                                <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"></path>
                                <circle cx="12" cy="10" r="3"></circle>
                            </svg>
                            Shipping Address
                        </h3>
                        <div class="info-content">
                            <p>
                                DoorNo: <%= orderData.address.doorNo %>
                            </p>
                            <p>
                                Street: <%= orderData.address.street %> ,City: <%= orderData.address.city %>
                            </p>
                            <p>
                                District: <%= orderData.address.district %>
                                    , Pincode: <%= orderData.address.pinCode %>
                            </p>
                        </div>
                    </div>

                    <div class="info-card">
                        <h3 class="info-title">
                            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24"
                                fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"
                                stroke-linejoin="round">
                                <rect x="1" y="4" width="22" height="16" rx="2" ry="2"></rect>
                                <line x1="1" y1="10" x2="23" y2="10"></line>
                            </svg>
                            Payment Information
                        </h3>
                        <div class="info-content">

                            <p><strong>Payment Method:</strong>
                                <%= orderData.paymentMethod %>
                            </p>


                            <p><strong>Payment Status:</strong>
                                <% if(orderData.status==='Delivered' || orderData.status==='Return processing' ||
                                    orderData.paymentMethod==='Wallet' ) { %>
                                    <span style="color: var(--success-color);">Pai</span>
                                    <% } else if(orderData.status==='Ordered' && orderData.paymentMethod==='Razorpay' )
                                        { %>
                                        <span style="color: var(--success-color);">Paid</span>
                                        <% } else if(orderData.status==='Ordered' &&
                                            orderData.paymentMethod==='Cash on delivery' ) { %>
                                            <span style="color: var(--warning-dark);">Pending</span>
                                            <% } else if(orderData.status==='Shipped' &&
                                                orderData.paymentMethod==='Razorpay' ) { %>
                                                <span style="color: var(--success-color);">Paid</span>
                                                <% } else if(orderData.status==='Shipped' &&
                                                    orderData.paymentMethod!=='Razorpay' ) { %>
                                                    <span style="color: var(--warning-dark);">Pending</span>
                                                    <% } else if(orderData.status==='Returned' ) { %>
                                                        <span style="color: var(--warning-dark);">Refunded</span>
                                                        <% } else { %>
                                                            <span style="color: var(--danger-color);">Failed</span>
                                                            <% } %>
                            </p>
                            <p><strong>Transaction ID:</strong>
                                <%= orderData.transactionId || 'N/A' %>
                            </p>
                        </div>
                    </div>
                </div>

                <h2 style="margin-bottom: 20px;">Order Items</h2>

                <div class="table-responsive">
                    <table class="product-table">
                        <thead>
                            <tr>
                                <th>Product Name</th>
                                <th>Price</th>
                                <th>Quantity</th>
                                <th>Status</th>
                                <th>Total</th>
                            </tr>
                        </thead>
                        <tbody>
                            <% orderData.products.forEach(item=> { %>
                                <tr>
                                    <td class="product-name">
                                        <%= item.productName %>
                                    </td>
                                    <td>
                                        <%= item.productPrice %>
                                    </td>
                                    <td>
                                        <%= item.quantity %>
                                    </td>
                                    <td>
                                        <span
                                            class="order-status status-<%= item.status ? item.status.toLowerCase() : orderData.status.toLowerCase() %>">
                                            <%= item.status || orderData.status %>
                                        </span>
                                    </td>
                                    <td>₹<%= (item.productPrice * item.quantity).toFixed(2) %>
                                    </td>
                                </tr>
                                <% }) %>
                        </tbody>
                    </table>
                </div>

                <div class="summary-section">
                    <div class="order-summary">
                        <div class="summary-row">
                            <span>Sub Total:</span>
                            <span>₹<%= orderData.priceDetails.subtotal.toFixed(2) %></span>
                        </div>

                        <% if(orderData.priceDetails.tax) { %>
                            <div class="summary-row">
                                <span>Tax:</span>
                                <span>₹<%= orderData.priceDetails.tax.toFixed(2) %></span>
                            </div>
                            <% } %>
                                <% if(orderData.priceDetails.couponDiscount) { %>
                                    <div class="summary-row">
                                        <span>Coupon:</span>
                                        <span style="color: green;">-₹<%=
                                                orderData.priceDetails.couponDiscount.toFixed(2) %></span>
                                    </div>
                                    <% }else{ %>
                                        <div class="summary-row">
                                            <span>Coupon:</span>
                                            <span>-₹0</span>
                                        </div>
                                        <% } %>
                                            <div class="summary-row">
                                                <span>Shipping Cost:</span>
                                                <span>Free</span>
                                            </div>
                                            <div class="summary-row">
                                                <span>Grand Total:</span>
                                                <span>₹<%= orderData.priceDetails.total.toFixed(2) %></span>
                                            </div>
                    </div>
                </div>

                <div class="action-buttons">
                    <a href="/orders" class="button outline-button">
                        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none"
                            stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                            <line x1="19" y1="12" x2="5" y2="12"></line>
                            <polyline points="12 19 5 12 12 5"></polyline>
                        </svg>
                        Back to Orders
                    </a>
                    <a href="/download-invoice/<%= orderData._id %>" class="button primary-button">
                        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none"
                            stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                            <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"></path>
                            <polyline points="7 10 12 15 17 10"></polyline>
                            <line x1="12" y1="15" x2="12" y2="3"></line>
                        </svg>
                        Download Invoice
                    </a>
                    <% if(orderData.status !=='Delivered' && orderData.status !=='Cancelled' && orderData.status
                        !=='Return processing' && orderData.status !=='Returned' && orderData.status
                        !=='Payment Pending' ) { %>
                        <button class="button danger-button" id="cancelOrderBtn">
                            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24"
                                fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"
                                stroke-linejoin="round">
                                <circle cx="12" cy="12" r="10"></circle>
                                <line x1="15" y1="9" x2="9" y2="15"></line>
                                <line x1="9" y1="9" x2="15" y2="15"></line>
                            </svg>
                            Cancel Order
                        </button>
                        <% } %>
                            <% if(orderData.status=='Delivered' ) { %>
                                <button class="button danger-button" id="returnOrderBtn">

                                    Return Order
                                </button>
                                <% } %>
                                    <% if(orderData.status==='Payment Pending' && orderData.paymentMethod==='Razorpay' )
                                        { %>
                                        <button class="button primary-button" id="retryPaymentBtn"
                                            style="background-color: rgb(218, 120, 120);">
                                            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18"
                                                viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"
                                                stroke-linecap="round" stroke-linejoin="round">
                                                <path
                                                    d="M21.5 2v6h-6M2.5 22v-6h6M22 11.5a10 10 0 0 1-10 10 10 10 0 0 1-10-10 10 10 0 0 1 10-10 10 10 0 0 1 10 10z">
                                                </path>
                                            </svg>
                                            Retry Payment
                                        </button>
                                        <% } %>
                </div>
            </div>
        </div>

        <%- include("../../views/partials/user/footers") %>
<script src="https://checkout.razorpay.com/v1/checkout.js"></script>
            <script>
                document.addEventListener('DOMContentLoaded', function () {
                    const cancelOrderBtn = document.getElementById('cancelOrderBtn');
                    const returnOrderBtn = document.getElementById('returnOrderBtn');
                    if (cancelOrderBtn) {
                        cancelOrderBtn.addEventListener('click', async function () {
                            const result = await Swal.fire({
                                title: 'Are you sure?',
                                text: "You won't be able to revert this!",
                                icon: 'warning',
                                showCancelButton: true,
                                confirmButtonColor: '#d33',
                                cancelButtonColor: '#3085d6',
                                confirmButtonText: 'Yes, cancel it!',
                                cancelButtonText: 'No, keep it'
                            });

                            if (result.isConfirmed) {
                                try {
                                    const response = await fetch('/cancelOrder/<%= orderData._id %>', {
                                        method: 'POST',
                                        headers: {
                                            'Content-Type': 'application/json'
                                        }
                                    });

                                    const data = await response.json();

                                    if (data.success) {
                                        await Swal.fire(
                                            'Cancelled!',
                                            'Your order has been cancelled.',
                                            'success'
                                        );
                                        window.location.reload();
                                    } else {
                                        Swal.fire(
                                            'Error!',
                                            data.message || 'Failed to cancel order',
                                            'error'
                                        );
                                    }
                                } catch (error) {
                                    console.error('Error:', error);
                                    Swal.fire(
                                        'Error!',
                                        'An error occurred while cancelling order',
                                        'error'
                                    );
                                }
                            }
                        });
                    }
                });


                if (returnOrderBtn) {
                    returnOrderBtn.addEventListener('click', async function () {
                        const { value: returnReason } = await Swal.fire({
                            title: 'Return Order',
                            input: 'textarea',
                            inputLabel: 'Reason for return',
                            inputPlaceholder: 'Please explain why you want to return this order...',
                            inputAttributes: {
                                'aria-label': 'Type your reason here'
                            },
                            showCancelButton: true,
                            confirmButtonColor: '#d33',
                            cancelButtonColor: '#3085d6',
                            confirmButtonText: 'Submit Return',
                            cancelButtonText: 'Cancel',
                            inputValidator: (value) => {
                                if (!value) {
                                    return 'You need to provide a reason for return!';
                                }
                            }
                        });

                        if (returnReason) {
                            try {
                                const response = await fetch('/returnOrder/<%= orderData._id %>', {
                                    method: 'POST',
                                    headers: {
                                        'Content-Type': 'application/json'
                                    },
                                    body: JSON.stringify({ value: returnReason })
                                });

                                const data = await response.json();

                                if (data.success) {
                                    await Swal.fire(
                                        'Return Requested!',
                                        'Your return request has been submitted successfully.',
                                        'success'
                                    );
                                    window.location.reload();
                                } else {
                                    Swal.fire(
                                        'Error!',
                                        data.message || 'Failed to process return request',
                                        'error'
                                    );
                                }
                            } catch (error) {
                                console.error('Error:', error);
                                Swal.fire(
                                    'Error!',
                                    'An error occurred while processing your return request',
                                    'error'
                                );
                            }
                        }
                    });
                }
            </script>
            <script>
                document.addEventListener('DOMContentLoaded', function () {
                    const retryPaymentBtn = document.getElementById('retryPaymentBtn');

                    if (retryPaymentBtn) {
                        retryPaymentBtn.addEventListener('click', async function () {
                            const orderId = '<%= orderData._id %>';
                            const orderTotal = '<%= orderData.priceDetails.total %>';

                            try {
                                // Show loading state
                                retryPaymentBtn.disabled = true;
                                retryPaymentBtn.innerHTML = `<span class="spinner"></span> Processing...`;

                                // Create Razorpay order
                                const orderResponse = await fetch('/create-razorpay-order', {
                                    method: 'POST',
                                    headers: {
                                        'Content-Type': 'application/json',
                                    },
                                    body: JSON.stringify({ amount: orderTotal })
                                });

                                const { order: razorpayOrder } = await orderResponse.json();

                                // Open Razorpay checkout
                                const options = {
                                    key: '<%= process.env.RAZORPAY_KEY_ID %>',
                                    amount: razorpayOrder.amount,
                                    currency: 'INR',
                                    name: 'Your Store Name',
                                    description: 'Retry Payment for Order #<%= orderData.orderId %>',
                                    order_id: razorpayOrder.id,
                                    handler: async function (response) {
                                        try {
                                            // Verify payment
                                            const verification = await fetch('/verify-payment', {
                                                method: 'POST',
                                                headers: {
                                                    'Content-Type': 'application/json',
                                                },
                                                body: JSON.stringify(response)
                                            });

                                            const result = await verification.json();

                                            if (result.success) {
                                                // Update the order status
                                                const updateResponse = await fetch(`/update-payment-status/${orderId}`, {
                                                    method: 'POST',
                                                    headers: {
                                                        'Content-Type': 'application/json',
                                                    },
                                                    body: JSON.stringify({
                                                        paymentId: response.razorpay_payment_id,
                                                        orderId: response.razorpay_order_id,
                                                        signature: response.razorpay_signature
                                                    })
                                                });

                                                const updateResult = await updateResponse.json();

                                                if (updateResult.success) {
                                                    Swal.fire({
                                                        title: 'Payment Successful!',
                                                        text: 'Your payment has been processed successfully.',
                                                        icon: 'success',
                                                        confirmButtonText: 'OK'
                                                    }).then(() => {
                                                        window.location.reload();
                                                    });
                                                } else {
                                                    throw new Error('Failed to update order status');
                                                }
                                            } else {
                                                throw new Error('Payment verification failed');
                                            }
                                        } catch (error) {
                                            console.error('Payment processing error:', error);
                                            Swal.fire({
                                                title: 'Error',
                                                text: error.message || 'Payment processing failed',
                                                icon: 'error',
                                                confirmButtonText: 'OK'
                                            });
                                        } finally {
                                            retryPaymentBtn.disabled = false;
                                            retryPaymentBtn.innerHTML = 'Retry Payment';
                                        }
                                    },
                                    theme: {
                                        color: '#00f2ea'
                                    }
                                };

                                const rzp = new Razorpay(options);
                                rzp.open();

                                rzp.on('payment.failed', function (response) {
                                    Swal.fire({
                                        title: 'Payment Failed',
                                        text: response.error.description || 'Payment failed. Please try again.',
                                        icon: 'error',
                                        confirmButtonText: 'OK'
                                    });
                                    retryPaymentBtn.disabled = false;
                                    retryPaymentBtn.innerHTML = 'Retry Payment';
                                });

                            } catch (error) {
                                console.error('Error:', error);
                                Swal.fire({
                                    title: 'Error',
                                    text: error.message || 'Failed to process payment',
                                    icon: 'error',
                                    confirmButtonText: 'OK'
                                });
                                retryPaymentBtn.disabled = false;
                                retryPaymentBtn.innerHTML = 'Retry Payment';
                            }
                        });
                    }
                });
            </script>
    </body>

    </html>