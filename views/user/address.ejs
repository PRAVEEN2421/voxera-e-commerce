<%- include("../../views/partials/user/headers") %>
<style>
    :root {
        --primary-color: #00f2ea;
        --primary-dark: #00d6d0;
        --text-dark: #333;
        --text-light: #666;
        --border-color: #eee;
        --bg-light: #fafafa;
        --bg-white: #ffffff;
        --shadow: 0 4px 12px rgba(0, 0, 0, 0.05);
        --radius: 12px;
        --radius-sm: 8px;
        --spacing-sm: 10px;
        --spacing-md: 20px;
        --spacing-lg: 30px;
    }

    * {
        box-sizing: border-box;
        margin: 0;
        padding: 0;
    }

    body {
        font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Oxygen, Ubuntu, Cantarell, 'Open Sans', 'Helvetica Neue', sans-serif;
        background-color: var(--bg-light);
        color: var(--text-dark);
        line-height: 1.6;
    }

    .page-content {
        width: 100%;
        margin: 0 auto;
        padding: 20px;
    }

    .Pcontainer {
        display: flex;
        gap: 30px;
        padding: 10px;
        flex-direction: row;
    }

    .sidebar {
        width: 300px;
        background-color: var(--bg-white);
        border-radius: var(--radius);
        padding: var(--spacing-md);
        box-shadow: var(--shadow);
        position: sticky;
        top: 20px;
        height: fit-content;
        transition: all 0.3s ease;
    }

    .main-content {
        flex: 1;
        min-width: 0;
    }

    .user {
        display: flex;
        align-items: center;
        gap: 15px;
        padding-bottom: 20px;
        border-bottom: 1px solid var(--border-color);
        margin-bottom: 20px;
    }

    .user-avatar {
            width: 64px;
            height: 64px;
            background-color: #f8e4e6;
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 24px;
            font-weight: bold;
            color: #e91e63;
            box-shadow: 0 2px 8px rgba(233, 30, 99, 0.2);
        }

        .user-info {
            display: flex;
            flex-direction: column;
        }

        .user-name {
            font-weight: 600;
            font-size: 18px;
            margin-bottom: 4px;
        }

        .user-email {
            color: var(--text-light);
            font-size: 14px;
        }

    .menu-section {
        margin-bottom: var(--spacing-lg);
    }

    .menu-title {
        font-weight: 600;
        margin-bottom: 15px;
        color: var(--text-light);
        font-size: 14px;
        text-transform: uppercase;
        letter-spacing: 0.5px;
    }

    .menu-section a {
        color: #333;
        text-decoration: none !important;
        font-weight: 600;
        font-size: 16px;
    }

    .menu-item {
        display: flex;
        align-items: center;
        padding: 12px 15px;
        margin-bottom: 8px;
        border-radius: var(--radius-sm);
        cursor: pointer;
        color: var(--text-dark);
        text-decoration: none;
        transition: all 0.2s ease;
        font-weight: 500;
    }

    .menu-item.active {
        background-color: rgba(0, 242, 234, 0.1);
        color: var(--primary-color);
        font-weight: 600;
    }

    .menu-item:hover:not(.active) {
        background-color: rgba(0, 0, 0, 0.03);
        transform: translateX(3px);
    }

    .logout-item {
        margin-top: 40px;
        color: #ff5252;
    }

    h1 {
        font-size: 28px;
        margin-bottom: 25px;
        font-weight: 700;
    }

    h2 {
        font-size: 20px;
        margin-bottom: 20px;
        font-weight: 600;
    }

    .form-section {
        margin-bottom: 30px;
        background-color: var(--bg-white);
        padding: 20px;
        border-radius: var(--radius);
        box-shadow: var(--shadow);
    }

    .form-section-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 25px;
        flex-wrap: wrap;
        gap: 15px;
    }

    .form-row {
        display: flex;
        gap: 20px;
        margin-bottom: 20px;
        flex-wrap: wrap;
    }

    .form-field {
        flex: 1;
        min-width: 0;
        min-width: 200px;
    }

    label {
        display: block;
        margin-bottom: 10px;
        font-weight: 500;
        color: var(--text-dark);
    }

    input[type="text"],
    input,
    input[type="email"],
    input[type="password"] {
        width: 100%;
        padding: 12px 15px;
        border: 1px solid #ddd;
        border-radius: var(--radius-sm);
        font-size: 16px;
        transition: all 0.2s ease;
    }

    input[type="text"]:focus,
    input[type="email"]:focus,
    input:focus,
    input[type="password"]:focus {
        border-color: var(--primary-color);
        outline: none;
        box-shadow: 0 0 0 3px rgba(0, 242, 234, 0.2);
    }

    input:disabled {
        background-color: #f5f5f5;
        cursor: not-allowed;
    }

    .button {
        padding: 12px 24px;
        border: none;
        border-radius: var(--radius-sm);
        font-size: 16px;
        font-weight: 500;
        cursor: pointer;
        margin-right: 10px;
        transition: all 0.2s ease;
        white-space: nowrap;
        display: flex;
        align-items: center;
        justify-content: center;
    }

    .primary-button {
        background-color: var(--primary-color);
        color: #000;
    }

    .primary-button:hover {
        background-color: var(--primary-dark);
        transform: translateY(-2px);
        box-shadow: 0 4px 8px rgba(0, 0, 0, 0.1);
    }

    .secondary-button {
        background-color: #f0f0f0;
        color: var(--text-dark);
    }

    .secondary-button:hover {
        background-color: #e0e0e0;
    }

    .divider {
        height: 1px;
        background-color: var(--border-color);
        margin: 30px 0;
    }

    .addresses-container {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
        gap: 20px;
    }

    .address-card {
        border: 1px solid var(--border-color);
        border-radius: var(--radius);
        padding: 20px;
        background-color: var(--bg-white);
        transition: all 0.2s ease;
        position: relative;
        box-shadow: 0 2px 8px rgba(0, 0, 0, 0.05);
    }

    .address-card:hover {
        box-shadow: var(--shadow);
        transform: translateY(-3px);
    }

    .address-card-header {
        display: flex;
        justify-content: space-between;
        align-items: flex-start;
        margin-bottom: 15px;
        border-bottom: 1px solid var(--border-color);
        padding-bottom: 10px;
        flex-wrap: wrap;
        gap: 10px;
    }

    .address-card-header h3 {
        margin: 0;
        font-size: 18px;
        font-weight: 600;
    }

    .address-label-container {
        display: flex;
        gap: 5px;
        flex-wrap: wrap;
    }

    .address-label {
        font-size: 12px;
        padding: 3px 8px;
        border-radius: 12px;
        font-weight: 500;
    }

    .address-label.primary {
        background-color: rgba(0, 242, 234, 0.1);
        color: var(--primary-color);
    }

    .address-label.home {
        background-color: rgba(76, 175, 80, 0.1);
        color: #4CAF50;
    }

    .address-label.office {
        background-color: rgba(33, 150, 243, 0.1);
        color: #2196F3;
    }

    .address-label.other {
        background-color: rgba(156, 39, 176, 0.1);
        color: #9C27B0;
    }

    .address-details {
        margin-bottom: 15px;
    }

    .address-details p {
        margin: 5px 0;
        color: var(--text-dark);
    }

    .address-actions {
        display: flex;
        gap: 10px;
        flex-wrap: wrap;
    }

    .address-actions button {
        background: none;
        border: 1px solid var(--border-color);
        padding: 8px 12px;
        border-radius: var(--radius-sm);
        cursor: pointer;
        font-size: 14px;
        transition: all 0.2s ease;
        flex: 1;
        min-width: 80px;
        display: flex;
        align-items: center;
        justify-content: center;
    }

    .edit-address-btn {
        color: #2196F3;
    }

    .edit-address-btn:hover {
        background-color: rgba(33, 150, 243, 0.1);
        border-color: #2196F3;
    }

    .set-default-btn {
        color: var(--primary-color);
    }

    .set-default-btn:hover {
        background-color: rgba(0, 242, 234, 0.1);
        border-color: var(--primary-color);
    }

    .delete-address-btn {
        color: #f44336;
    }

    .delete-address-btn:hover {
        background-color: rgba(244, 67, 54, 0.1);
        border-color: #f44336;
    }

    .no-address-container {
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        padding: 60px 0;
        text-align: center;
    }

    .no-address-container p {
        margin: 20px 0;
        color: var(--text-light);
        font-size: 16px;
    }

    .modal {
        display: none;
        position: fixed;
        z-index: 1000;
        left: 0;
        top: 0;
        width: 100%;
        height: 100%;
        overflow: auto;
        background-color: rgba(0, 0, 0, 0.4);
    }

    .modal-content {
        background-color: var(--bg-white);
        margin: 5% auto;
        width: 90%;
        max-width: 600px;
        border-radius: var(--radius);
        box-shadow: 0 10px 25px rgba(0, 0, 0, 0.1);
        animation: modalFadeIn 0.3s;
    }

    @keyframes modalFadeIn {
        from {
            opacity: 0;
            transform: translateY(-30px);
        }

        to {
            opacity: 1;
            transform: translateY(0);
        }
    }

    .modal-header {
        padding: 20px;
        border-bottom: 1px solid var(--border-color);
        display: flex;
        justify-content: space-between;
        align-items: center;
    }

    .modal-header h2 {
        margin: 0;
        font-size: 20px;
    }

    .close-modal {
        color: var(--text-light);
        font-size: 28px;
        font-weight: bold;
        cursor: pointer;
    }

    .close-modal:hover {
        color: var(--text-dark);
    }

    .modal-body {
        padding: 20px;
    }

    .modal-footer {
        padding: 20px;
        display: flex;
        justify-content: flex-end;
        gap: 10px;
        flex-wrap: wrap;
    }

    .error {
        color: red;
        font-size: 0.85em;
        display: block;
        margin-top: 5px;
    }

    .checkbox-field {
        display: flex;
        align-items: center;
        gap: 10px;
        margin-top: 15px;
    }

    .checkbox-field input {
        width: auto;
    }

    .checkbox-field label {
        margin-bottom: 0;
        cursor: pointer;
    }

    .toast-container {
        position: fixed;
        top: 20px;
        right: 20px;
        z-index: 9999;
    }

    .toast {
        display: none;
        background-color: #ff6600;
        color: white;
        padding: 15px 30px;
        border-radius: 12px;
        font-size: 16px;
        text-align: center;
        box-shadow: 0 8px 20px rgba(0, 0, 0, 0.2);
        opacity: 0;
        transform: translateX(100%);
        animation: slideInFromRight 0.8s ease-out forwards;
        max-width: 90%;
    }

    @keyframes slideInFromRight {
        0% {
            opacity: 0;
            transform: translateX(100%);
        }

        100% {
            opacity: 1;
            transform: translateX(0);
        }
    }

    @keyframes slideOutToRight {
        0% {
            opacity: 1;
            transform: translateX(0);
        }

        100% {
            opacity: 0;
            transform: translateX(100%);
        }
    }

    select {
        width: 100%;
        padding: 12px 15px;
        border: 1px solid #ddd;
        border-radius: var(--radius-sm);
        font-size: 16px;
        background-color: var(--bg-white);
        transition: all 0.2s ease;
        appearance: none;
        background-image: url("data:image/svg+xml;charset=UTF-8,%3csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 24 24' fill='none' stroke='currentColor' stroke-width='2' stroke-linecap='round' stroke-linejoin='round'%3e%3cpolyline points='6 9 12 15 18 9'%3e%3c/polyline%3e%3c/svg%3e");
        background-repeat: no-repeat;
        background-position: right 15px center;
        background-size: 15px;
    }

    /* Mobile hamburger menu */
    .mobile-menu-button {
        display: none;
        background: none;
        border: none;
        cursor: pointer;
        padding: 10px;
        margin-bottom: 15px;
    }

    .mobile-menu-icon {
        width: 30px;
        height: 20px;
        position: relative;
        transform: rotate(0deg);
        transition: .5s ease-in-out;
        cursor: pointer;
    }

    .mobile-menu-icon span {
        display: block;
        position: absolute;
        height: 3px;
        width: 100%;
        background: var(--text-dark);
        border-radius: 3px;
        opacity: 1;
        left: 0;
        transform: rotate(0deg);
        transition: .25s ease-in-out;
    }

    .mobile-menu-icon span:nth-child(1) {
        top: 0px;
    }

    .mobile-menu-icon span:nth-child(2),
    .mobile-menu-icon span:nth-child(3) {
        top: 8px;
    }

    .mobile-menu-icon span:nth-child(4) {
        top: 16px;
    }

    .mobile-menu-icon.open span:nth-child(1) {
        top: 8px;
        width: 0%;
        left: 50%;
    }

    .mobile-menu-icon.open span:nth-child(2) {
        transform: rotate(45deg);
    }

    .mobile-menu-icon.open span:nth-child(3) {
        transform: rotate(-45deg);
    }

    .mobile-menu-icon.open span:nth-child(4) {
        top: 8px;
        width: 0%;
        left: 50%;
    }

    /* Responsive styles */
    @media (max-width: 992px) {
        .Pcontainer {
            flex-direction: column;
        }

        .sidebar {
            width: 100%;
            position: relative;
            top: 0;
            margin-bottom: 20px;
            order: 1;
        }

        .main-content {
            order: 2;
        }

        .mobile-menu-button {
            display: block;
        }

        .sidebar.collapsed {
            max-height: 90px;
            overflow: hidden;
        }

        .sidebar.collapsed .menu-section {
            display: none;
        }

        .modal-content {
            width: 95%;
            margin: 10% auto;
        }

        .form-section-header {
            flex-direction: column;
            align-items: flex-start;
        }

        .form-section-header button {
            width: 100%;
        }
        .user {
                padding-bottom: 15px;
                margin-bottom: 15px;
            }
    }

    @media (max-width: 768px) {
        .page-content {
            padding: 10px;
        }

        .form-section {
            padding: 15px;
        }

        .addresses-container {
            grid-template-columns: 1fr;
        }

        .form-row {
            flex-direction: column;
            gap: 15px;
        }

        .form-field {
            width: 100%;
        }

        .address-card-header {
            flex-direction: column;
        }

        .address-actions {
            flex-direction: column;
        }

        .address-actions button {
            width: 100%;
        }

        .modal-footer {
            flex-direction: column;
        }

        .modal-footer button {
            width: 100%;
        }
    }

    @media (max-width: 576px) {
    

        .user-info {
            text-align: center;
        }

        .modal-content {
            margin: 5% auto;
        }

        .modal-body {
            padding: 0px;
            height: 500px;
        }

        .user {
                padding-bottom: 15px;
                margin-bottom: 15px;
            }
    }
</style>

<body>
    
        <div class="toast-container"></div>

        <div class="page-content">
            <div class="Pcontainer">
                <div class="sidebar">
                    <div class="user">
                        <div class="user-avatar">
                            <%= userVer.name.charAt(0).toUpperCase() %>
                        </div>
                        <div class="user-info">
                            <div class="user-name">
                                <%= userVer.name %>
                            </div>
                            <div class="user-email">
                                <%= userVer.email %>
                            </div>
                        </div>
                    </div>

                    <div class="menu-section">
                        <a href="/profile" class="menu-item">
                            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24"
                                fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"
                                stroke-linejoin="round" style="margin-right: 10px;">
                                <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"></path>
                                <circle cx="12" cy="7" r="4"></circle>
                            </svg>
                            Personal Info
                        </a>
                        <a href="/address" class="menu-item active">
                            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24"
                                fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"
                                stroke-linejoin="round" style="margin-right: 10px;">
                                <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"></path>
                                <circle cx="12" cy="10" r="3"></circle>
                            </svg>
                            Addresses
                        </a>
                        <a href="/wishlist" class="menu-item">
                            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24"
                                fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"
                                stroke-linejoin="round" style="margin-right: 10px;">
                                <path
                                    d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78L12 21.23l8.84-8.84a5.5 5.5 0 0 0 0-7.78z">
                                </path>
                            </svg>
                            Wishlist
                        </a>
                        <a href="/wallet" class="menu-item">
                            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24"
                                fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"
                                stroke-linejoin="round" style="margin-right: 10px;">
                                <rect x="2" y="5" width="20" height="14" rx="2"></rect>
                                <line x1="16" y1="12" x2="16" y2="12"></line>
                            </svg>
                            Wallet
                        </a>
                        <a href="/orders" class="menu-item">
                            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24"
                                fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"
                                stroke-linejoin="round" style="margin-right: 10px;">
                                <path d="M6 2L3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4z"></path>
                                <line x1="3" y1="6" x2="21" y2="6"></line>
                                <path d="M16 10a4 4 0 0 1-8 0"></path>
                            </svg>
                            Orders
                        </a>

                        <a href="#" class="menu-item logout-item"
                            onclick="document.getElementById('logoutForm').submit(); return false;">
                            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24"
                                fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"
                                stroke-linejoin="round" style="margin-right: 10px;">
                                <path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"></path>
                                <polyline points="16 17 21 12 16 7"></polyline>
                                <line x1="21" y1="12" x2="9" y2="12"></line>
                            </svg>
                            Log out
                        </a>
                    </div>

                    <form id="logoutForm" action="/logout" method="post" style="display: none"></form>
                </div>

                <div class="main-content">
                    <div class="form-section">
                        <div class="form-section-header">
                            <h2>My Addresses</h2>
                            <button type="button" class="button primary-button" id="addAddressBtn">
                                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24"
                                    fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"
                                    stroke-linejoin="round" style="margin-right: 5px;">
                                    <line x1="12" y1="5" x2="12" y2="19"></line>
                                    <line x1="5" y1="12" x2="19" y2="12"></line>
                                </svg>
                                Add New Address
                            </button>
                        </div>

                        <% if (addresses && addresses.length> 0) { %>
                            <div class="addresses-container">
                                <% addresses.forEach(function(address) { %>
                                    <div class="address-card">
                                        <div class="address-card-header">

                                            <h3>
                                                <%= name || address.type %>
                                                    <!-- <%= name %> -->
                                            </h3>
                                            <div class="address-label-container">
                                                <% if (address.isDefault) { %>
                                                    <span class="address-label primary">Primary</span>
                                                    <% } %>
                                                        <span class="address-label <%= address.type.toLowerCase() %>">
                                                            <%= address.type %>
                                                        </span>
                                            </div>
                                        </div>
                                        <div class="address-details">
                                            <p>

                                                <%= address.doorNo %>, <%= address.street %>
                                            </p>
                                            <p>

                                                <%= address.city %>, <%= address.district %>
                                            </p>
                                            <p>

                                                Postcode: <%= address.pinCode || address.zipCode %>
                                            </p>
                                            <% if (address.phone) { %>
                                                <p>

                                                    Phone: <%= address.phone %>
                                                </p>
                                                <% } %>
                                        </div>
                                        <div class="address-actions">
                                            <button class="edit-address-btn" data-id="<%= address._id %>">
                                                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16"
                                                    viewBox="0 0 24 24" fill="none" stroke="currentColor"
                                                    stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                                    <path d="M12 20h9"></path>
                                                    <path d="M16.5 3.5a2.121 2.121 0 0 1 3 3L7 19l-4 1 1-4L16.5 3.5z">
                                                    </path>
                                                </svg>
                                                Edit
                                            </button>
                                            <% if (!address.isDefault) { %>
                                                <button class="set-default-btn" data-id="<%= address._id %>">
                                                    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16"
                                                        viewBox="0 0 24 24" fill="none" stroke="currentColor"
                                                        stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                                        <path
                                                            d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z">
                                                        </path>
                                                    </svg>
                                                    Set as Default
                                                </button>
                                                <button class="delete-address-btn" data-id="<%= address._id %>">
                                                    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16"
                                                        viewBox="0 0 24 24" fill="none" stroke="currentColor"
                                                        stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                                        <polyline points="3 6 5 6 21 6"></polyline>
                                                        <path
                                                            d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2">
                                                        </path>
                                                        <line x1="10" y1="11" x2="10" y2="17"></line>
                                                        <line x1="14" y1="11" x2="14" y2="17"></line>
                                                    </svg>
                                                    Delete
                                                </button>
                                                <% } %>
                                        </div>
                                    </div>
                                    <% }); %>
                            </div>
                            <% } else { %>
                                <div class="no-address-container">
                                    <svg xmlns="http://www.w3.org/2000/svg" width="60" height="60" viewBox="0 0 24 24"
                                        fill="none" stroke="var(--text-light)" stroke-width="1" stroke-linecap="round"
                                        stroke-linejoin="round">
                                        <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"></path>
                                        <circle cx="12" cy="10" r="3"></circle>
                                    </svg>
                                    <p>You haven't added any addresses yet</p>

                                </div>
                                <% } %>
                    </div>
                </div>
            </div>
        </div>

        <!-- Address Form Modal -->
        <div id="addressModal" class="modal">
            <div class="modal-content">
                <div class="modal-header">
                    <h2 id="modalTitle">Add New Address</h2>
                    <span class="close-modal">&times;</span>
                </div>
                <div class="modal-body">
                    <form id="addressForm">
                        <input type="hidden" id="addressId" name="addressId">
                        <input type="hidden" id="userid" name="userid" value="<%= userVer?._id %>">

                        <div class="form-row">
                            <div class="form-field">
                                <label for="doorNo">Door No:</label>
                                <input type="text" class="data-input" id="doorNo" name="doorNo">
                                <span class="error" id="doorNoError"></span>
                            </div>
                            <div class="form-field">
                                <label for="street">Street:</label>
                                <input type="text" class="data-input" id="street" name="street">
                                <span class="error" id="streetError"></span>
                            </div>
                        </div>

                        <div class="form-row">
                            <div class="form-field">
                                <label for="city">City:</label>
                                <input type="text" class="data-input" id="city" name="city">
                                <span class="error" id="cityError"></span>
                            </div>
                            <div class="form-field">
                                <label for="district">District:</label>
                                <input type="text" class="data-input" id="district" name="district">
                                <span class="error" id="districtError"></span>
                            </div>
                        </div>

                        <div class="form-row">
                            <div class="form-field">
                                <label for="postcode">Postcode:</label>
                                <input class="data-input" id="postcode" name="postcode" maxlength="6">
                                <span class="error" id="postcodeError"></span>
                            </div>
                            <div class="form-field">
                                <label for="addressType">Address Type</label>
                                <select id="addressType" name="type">
                                    <option value="Home">Home</option>
                                    <option value="Office">Office</option>
                                    <option value="Other">Other</option>
                                </select>
                            </div>
                        </div>

                        <div class="form-field checkbox-field">
                            <input type="checkbox" id="isDefault" name="isDefault">
                            <label for="isDefault">Set as default address</label>
                        </div>

                        <div class="modal-footer">
                            <button type="button" class="button secondary-button" id="cancelAddressBtn">Cancel</button>
                            <button type="submit" class="button primary-button">Save Address</button>
                        </div>
                    </form>
                </div>
            </div>
        </div>

        <%- include("../../views/partials/user/footers") %>
            <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
            <script>document.addEventListener('DOMContentLoaded', function () {
                    const addressModal = document.getElementById('addressModal');
                    const modalTitle = document.getElementById('modalTitle');
                    const addAddressBtn = document.getElementById('addAddressBtn');
                    const cancelAddressBtn = document.getElementById('cancelAddressBtn');
                    const closeModal = document.querySelector('.close-modal');
                    const addressForm = document.getElementById('addressForm');

                    // Open modal for adding new address
                    function openAddModal() {
                        modalTitle.textContent = 'Add New Address';
                        addressForm.reset();
                        document.getElementById('addressId').value = '';
                        addressModal.style.display = 'block';
                    }

                    if (addAddressBtn) {
                        addAddressBtn.addEventListener('click', openAddModal);
                    }

                    // Close modal 
                    function closeAddressModal() {
                        addressModal.style.display = 'none';
                        document.querySelectorAll('.error').forEach(error => error.textContent = '');

                    }

                    if (cancelAddressBtn) {
                        cancelAddressBtn.addEventListener('click', closeAddressModal);
                    }

                    if (closeModal) {
                        closeModal.addEventListener('click', closeAddressModal);
                    }

                    // Close modal when clicking outside of it
                    window.addEventListener('click', function (event) {
                        if (event.target === addressModal) {
                            closeAddressModal();
                        }
                    });

                    // Fetch address data for editing
                    async function fetchAddressData(addressId) {
                        try {
                            const response = await fetch(`/address/${addressId}`);
                            const data = await response.json();

                            if (data.success) {
                                // Fill form with address data
                                modalTitle.textContent = 'Edit Address';
                                document.getElementById('addressId').value = data.address._id;
                                document.getElementById('doorNo').value = data.address.doorNo;
                                document.getElementById('street').value = data.address.street;
                                document.getElementById('city').value = data.address.city;
                                document.getElementById('district').value = data.address.district;
                                document.getElementById('postcode').value = data.address.pinCode;
                                document.getElementById('addressType').value = data.address.type;
                                document.getElementById('isDefault').checked = data.address.isDefault;

                                // Show modal
                                addressModal.style.display = 'block';
                            } else {
                                showToast(data.message, 'error');
                            }
                        } catch (error) {
                            console.error('Error:', error);
                            showToast('Error fetching address data', 'error');
                        }
                    }

                    // Edit address functionality
                    const editAddressBtns = document.querySelectorAll('.edit-address-btn');
                    editAddressBtns.forEach(button => {
                        button.addEventListener('click', function () {
                            const addressId = this.getAttribute('data-id');
                            fetchAddressData(addressId);
                        });
                    });

                    // Delete address functionality with SweetAlert
                    const deleteAddressBtns = document.querySelectorAll('.delete-address-btn');
                    deleteAddressBtns.forEach(button => {
                        button.addEventListener('click', async function () {
                            const addressId = this.getAttribute('data-id');

                            // Use SweetAlert instead of confirm
                            Swal.fire({
                                title: 'Are you sure?',
                                text: "You won't be able to revert this!",
                                icon: 'warning',
                                showCancelButton: true,
                                confirmButtonColor: '#00f2ea',
                                cancelButtonColor: '#d33',
                                confirmButtonText: 'Yes, delete it!',
                                cancelButtonText: 'Cancel',
                                borderRadius: '12px'
                            }).then(async (result) => {
                                if (result.isConfirmed) {
                                    try {
                                        const response = await fetch(`/deleteAddress/${addressId}`, {
                                            method: 'DELETE'
                                        });
                                        const result = await response.json();

                                        if (result.success) {
                                            Swal.fire({
                                                title: 'Deleted!',
                                                text: result.message,
                                                icon: 'success',
                                                confirmButtonColor: '#00f2ea'
                                            }).then(() => {
                                                window.location.reload();
                                            });
                                        } else {
                                            Swal.fire({
                                                title: 'Error!',
                                                text: result.message,
                                                icon: 'error',
                                                confirmButtonColor: '#00f2ea'
                                            });
                                        }
                                    } catch (error) {
                                        console.error('Error:', error);
                                        Swal.fire({
                                            title: 'Error!',
                                            text: 'An error occurred while deleting the address',
                                            icon: 'error',
                                            confirmButtonColor: '#00f2ea'
                                        });
                                    }
                                }
                            });
                        });
                    });

                    // Set as default functionality
                    const setDefaultBtns = document.querySelectorAll('.set-default-btn');
                    setDefaultBtns.forEach(button => {
                        button.addEventListener('click', async function () {
                            const addressId = this.getAttribute('data-id');
                            try {
                                const response = await fetch(`/address/${addressId}/default`, {
                                    method: 'PATCH'
                                });
                                const result = await response.json();
                                showToast(result.message, result.success ? 'success' : 'error');
                                if (result.success) {
                                    setTimeout(() => window.location.reload(), 1500);
                                }
                            } catch (error) {
                                console.error('Error:', error);
                                showToast('An error occurred', 'error');
                            }
                        });
                    });
                    document.getElementById('doorNoError').textContent =
                        // Form submission with validation
                        addressForm.addEventListener('submit', async function (e) {
                            e.preventDefault();

                            let isValid = true;
                            document.querySelectorAll('.error').forEach(error => error.textContent = '');

                            // Validate Door No
                            const doorNo = document.getElementById('doorNo');
                            const doorNoValue = doorNo.value.trim();
                            if (!doorNoValue) {
                                document.getElementById('doorNoError').textContent = 'Door No is required';
                                isValid = false;
                            } else if (!/^\d+$/.test(doorNoValue)) {  // Test the value, not the element
                                document.getElementById('doorNoError').textContent = 'doorNo must be numbers only';
                                isValid = false;
                            }

                            // Validate Street
                            const street = document.getElementById('street');
                            if (!street.value.trim()) {
                                document.getElementById('streetError').textContent = 'Street is required';
                                isValid = false;
                            }

                            // Validate City
                            const city = document.getElementById('city');
                            if (!city.value.trim()) {
                                document.getElementById('cityError').textContent = 'City is required';
                                isValid = false;
                            }

                            // Validate District
                            const district = document.getElementById('district');
                            if (!district.value.trim()) {
                                document.getElementById('districtError').textContent = 'District is required';
                                isValid = false;
                            }

                            // Validate Postcode
                            const postcode = document.getElementById('postcode');
                            const postcodeValue = postcode.value.trim();
                            if (!postcodeValue) {
                                document.getElementById('postcodeError').textContent = 'Postcode is required';
                                isValid = false;
                            } else if (!/^[0-9]{6}$/.test(postcodeValue)) {
                                document.getElementById('postcodeError').textContent = 'Postcode must be a 6-digit number';
                                isValid = false;
                            }

                            if (isValid) {
                                const formData = {
                                    doorNo: document.getElementById('doorNo').value.trim(),
                                    street: document.getElementById('street').value.trim(),
                                    city: document.getElementById('city').value.trim(),
                                    district: document.getElementById('district').value.trim(),
                                    postcode: document.getElementById('postcode').value.trim(),
                                    type: document.getElementById('addressType').value,
                                    isDefault: document.getElementById('isDefault').checked,
                                    userId: document.getElementById('userid').value
                                };

                                try {
                                    const addressId = document.getElementById('addressId').value;
                                    const url = addressId ? `/address/${addressId}` : '/addAddress';
                                    const method = addressId ? 'PUT' : 'POST';

                                    const response = await fetch(url, {
                                        method: method,
                                        headers: { 'Content-Type': 'application/json' },
                                        body: JSON.stringify(formData)
                                    });

                                    const result = await response.json();

                                    if (result.success) {
                                        Swal.fire({
                                            title: 'Success!',
                                            text: result.message,
                                            icon: 'success',
                                            confirmButtonColor: '#00f2ea'
                                        }).then(() => {
                                            window.location.reload();
                                        });
                                    } else {
                                        showToast(result.message, 'error');
                                    }
                                } catch (error) {
                                    console.error('Error:', error);
                                    showToast('An error occurred', 'error');
                                }
                            }
                        });

                    // Toast notification function
                    function showToast(message, type) {
                        const toastContainer = document.querySelector(".toast-container");
                        const toast = document.createElement("div");
                        toast.className = `toast ${type}`;
                        toast.textContent = message;
                        toast.style.backgroundColor = type === 'success' ? "#28a745" : "#dc3545";
                        toastContainer.appendChild(toast);

                        setTimeout(() => {
                            toast.style.display = "block";
                            setTimeout(() => {
                                toast.style.animation = "slideOutToRight 0.8s ease-out forwards";
                                setTimeout(() => {
                                    toast.remove();
                                }, 800);
                            }, 3000);
                        }, 100);
                    }
                });
            </script>
</body>