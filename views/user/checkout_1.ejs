<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Voxera</title>
    <link rel="icon" href="/img/icon.png" type="image/png" />
    <!-- Toast Notification CSS -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/toastify-js/src/toastify.min.css">
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
            font-family: 'Poppins', sans-serif;
        }

        body {
            background-color: #f5f7fb;
            color: #2d3748;
            line-height: 1.6;
        }

        .container {
            max-width: 1100px;
            margin: 0 auto;
            padding: 30px 20px;
        }

        /* Checkout Header Styles */
        .checkout-header {
            margin-bottom: 40px;
            text-align: center;
        }

        .checkout-header h1 {
            font-size: 32px;
            font-weight: 700;
            margin-bottom: 15px;
            color: #303b5a;
            letter-spacing: -0.5px;
        }

        /* Progress Bar */
        .checkout-progress {
            position: relative;
            margin: 40px auto;
            max-width: 600px;
        }

        .progress-bar {
            position: relative;
            display: flex;
            justify-content: space-between;
            counter-reset: step;
        }

        .progress-bar::before {
            content: "";
            position: absolute;
            top: 20px;
            left: 0;
            width: 100%;
            height: 3px;
            background-color: #e2e8f0;
            z-index: 1;
        }

        .progress-bar::after {
            content: "";
            position: absolute;
            top: 20px;
            left: 0;
            width: 33.33%;
            height: 3px;
            background-color: #00f2ea;
            z-index: 1;
            transition: width 0.3s ease;
        }

        .step {
            position: relative;
            z-index: 2;
            text-align: center;
            width: 40px;
            height: 40px;
        }

        .step-icon {
            width: 40px;
            height: 40px;
            border-radius: 50%;
            background-color: #e2e8f0;
            color: #94a3b8;
            display: flex;
            align-items: center;
            justify-content: center;
            font-weight: 600;
            margin-bottom: 10px;
            transition: all 0.3s ease;
        }

        .step.active .step-icon {
            background-color: #00f2ea;
            color: #fff;
            box-shadow: 0 0 0 5px rgba(0, 242, 234, 0.2);
        }

        .step.completed .step-icon {
            background-color: #10b981;
            color: #fff;
        }

        .step-label {
            position: absolute;
            top: 45px;
            left: 50%;
            transform: translateX(-50%);
            font-size: 14px;
            font-weight: 500;
            white-space: nowrap;
            color: #94a3b8;
        }

        .step.active .step-label {
            color: #334155;
            font-weight: 600;
        }

        /* Checkout Content */
        .checkout-content {
            background-color: #fff;
            border-radius: 16px;
            box-shadow: 0 10px 30px rgba(0, 0, 0, 0.05);
            padding: 40px;
            margin-bottom: 30px;
            transition: all 0.3s ease;
        }

        .checkout-content:hover {
            box-shadow: 0 15px 40px rgba(0, 0, 0, 0.08);
        }

        .section-title {
            font-size: 24px;
            font-weight: 600;
            margin-bottom: 25px;
            color: #303b5a;
            display: flex;
            align-items: center;
        }

        .section-title svg {
            margin-right: 10px;
            color: #00f2ea;
        }

        /* Contact Information Section */
        .contact-info {
            border-bottom: 1px solid #e2e8f0;
            padding-bottom: 30px;
            margin-bottom: 30px;
        }

        /* Form Styles */
        .form-row {
            display: flex;
            flex-wrap: wrap;
            margin: 0 -12px 20px;
        }

        .form-group {
            flex: 1 0 200px;
            padding: 0 12px;
            margin-bottom: 20px;
            position: relative;
        }

        .form-group.full-width {
            flex: 1 0 100%;
        }

        .form-label {
            display: block;
            margin-bottom: 8px;
            font-weight: 500;
            font-size: 14px;
            color: #4b5563;
        }

        .form-control {
            width: 100%;
            padding: 14px 16px;
            border: 1.5px solid #e2e8f0;
            border-radius: 10px;
            font-size: 15px;
            transition: all 0.3s ease;
            color: #2d3748;
        }

        .form-control:focus {
            border-color: #00f2ea;
            outline: none;
            box-shadow: 0 0 0 3px rgba(0, 242, 234, 0.15);
        }

        .form-control.error {
            border-color: #ef4444;
        }

        .error-message {
            color: #ef4444;
            font-size: 12px;
            margin-top: 5px;
            display: none;
            position: absolute;
            bottom: -20px;
            left: 12px;
        }

        .error-message.show {
            display: block;
        }

        /* Address Selection */
        .saved-addresses {
            margin-bottom: 30px;
        }

        .address-list {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
            gap: 20px;
            margin-bottom: 20px;
        }

        .address-card {
            border: 1.5px solid #e2e8f0;
            border-radius: 12px;
            padding: 20px;
            cursor: pointer;
            transition: all 0.3s ease;
            display: flex;
            align-items: flex-start;
            position: relative;
            overflow: hidden;
        }

        .address-card:hover {
            border-color: #00f2ea;
            transform: translateY(-2px);
            box-shadow: 0 8px 20px rgba(0, 0, 0, 0.05);
        }

        .address-card.selected {
            border-color: #00f2ea;
            background-color: rgba(0, 242, 234, 0.05);
        }

        .address-card.selected::before {
            content: "";
            position: absolute;
            top: 0;
            left: 0;
            width: 4px;
            height: 100%;
            background-color: #00f2ea;
            border-top-left-radius: 10px;
            border-bottom-left-radius: 10px;
        }

        .address-selector {
            margin-right: 15px;
            margin-top: 3px;
        }

        .address-selector input[type="radio"] {
            width: 18px;
            height: 18px;
            accent-color: #00f2ea;
        }

        .address-content {
            flex: 1;
        }

        .address-type {
            display: inline-block;
            padding: 2px 10px;
            border-radius: 20px;
            background-color: #f1f5f9;
            font-size: 12px;
            font-weight: 500;
            margin-bottom: 8px;
            color: #475569;
        }

        .address-type.Home {
            background-color: #ecfdf5;
            color: #059669;
        }

        .address-type.Office {
            background-color: #eff6ff;
            color: #3b82f6;
        }

        .address-type.Other {
            background-color: #fef3c7;
            color: #d97706;
        }

        .address-name {
            font-weight: 600;
            margin-bottom: 5px;
            font-size: 16px;
        }

        .address-phone {
            color: #64748b;
            margin-bottom: 8px;
            font-size: 14px;
        }

        .address-details {
            color: #64748b;
            font-size: 14px;
            line-height: 1.5;
        }

        /* New Address Button */
        .new-address-btn {
            display: inline-flex;
            align-items: center;
            padding: 12px 20px;
            background-color: #f8fafc;
            border: 1.5px dashed #cbd5e1;
            border-radius: 10px;
            font-size: 15px;
            font-weight: 500;
            color: #64748b;
            cursor: pointer;
            transition: all 0.3s ease;
        }

        .new-address-btn:hover {
            border-color: #00f2ea;
            color: #00f2ea;
            background-color: rgba(0, 242, 234, 0.05);
        }

        .new-address-btn svg {
            margin-right: 8px;
        }

        /* Checkbox Styles */
        .save-address-row {
            display: flex;
            align-items: center;
            margin-bottom: 20px;
        }

        .checkbox-container {
            display: flex;
            align-items: center;
            cursor: pointer;
        }

        .checkbox-container input {
            width: 18px;
            height: 18px;
            margin-right: 8px;
            accent-color: #00f2ea;
        }

        /* Action Buttons */
        .checkout-actions {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-top: 30px;
            padding-top: 20px;
            border-top: 1px solid #e2e8f0;
        }

        .btn {
            padding: 12px 24px;
            border-radius: 10px;
            font-size: 16px;
            font-weight: 500;
            cursor: pointer;
            transition: all 0.3s ease;
            border: none;
            outline: none;
            text-decoration: none;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            min-width: 150px;
        }

        .btn svg {
            margin-right: 8px;
        }

        .btn-primary {
            background-color: #00f2ea;
            color: #0c4a47;
            box-shadow: 0 4px 15px rgba(0, 242, 234, 0.2);
        }

        .btn-primary:hover {
            background-color: #00dad3;
            transform: translateY(-2px);
            box-shadow: 0 8px 20px rgba(0, 242, 234, 0.25);
        }

        .btn-outline {
            background-color: transparent;
            border: 1.5px solid #cbd5e1;
            color: #64748b;
        }

        .btn-outline:hover {
            border-color: #94a3b8;
            color: #475569;
            background-color: #f8fafc;
        }

        /* Modal Styles */
        .modal {
            display: none;
            position: fixed;
            z-index: 100;
            left: 0;
            top: 0;
            width: 100%;
            height: 100%;
            overflow: auto;
            background-color: rgba(0, 0, 0, 0.5);
            animation: fadeIn 0.3s ease;
        }

        @keyframes fadeIn {
            from {
                opacity: 0;
            }

            to {
                opacity: 1;
            }
        }

        .modal-content {
            background-color: #fff;
            margin: 5% auto;
            padding: 40px;
            border-radius: 16px;
            width: 90%;
            max-width: 700px;
            box-shadow: 0 15px 50px rgba(0, 0, 0, 0.1);
            position: relative;
            animation: slideIn 0.4s ease;
            max-height: 90vh;
            overflow-y: auto;
        }

        @keyframes slideIn {
            from {
                transform: translateY(20px);
                opacity: 0;
            }

            to {
                transform: translateY(0);
                opacity: 1;
            }
        }

        .close-modal {
            position: absolute;
            right: 20px;
            top: 20px;
            font-size: 24px;
            cursor: pointer;
            color: #94a3b8;
            width: 36px;
            height: 36px;
            display: flex;
            align-items: center;
            justify-content: center;
            border-radius: 50%;
            transition: all 0.3s ease;
        }

        .close-modal:hover {
            color: #475569;
            background-color: #f1f5f9;
        }

        .modal-title {
            font-size: 24px;
            font-weight: 600;
            margin-bottom: 25px;
            color: #303b5a;
        }

        .modal-footer {
            margin-top: 30px;
            display: flex;
            justify-content: flex-end;
            gap: 15px;
        }

        /* Radio button styles */
        .radio-container {
            display: flex;
            margin-bottom: 15px;
            flex-wrap: wrap;
            gap: 15px;
        }

        .radio-option {
            margin-right: 20px;
            display: flex;
            align-items: center;
        }

        .radio-option input {
            width: 18px;
            height: 18px;
            margin-right: 8px;
            accent-color: #00f2ea;
        }

        /* Empty State */
        .empty-addresses {
            text-align: center;
            padding: 40px 20px;
            background-color: #f8fafc;
            border-radius: 12px;
            margin-bottom: 20px;
        }

        .empty-icon {
            margin-bottom: 15px;
            color: #cbd5e1;
        }

        .empty-text {
            color: #64748b;
            font-size: 16px;
            margin-bottom: 20px;
        }

        /* Loading Styles */
        .loading {
            display: inline-block;
            width: 20px;
            height: 20px;
            border: 2px solid rgba(255, 255, 255, 0.3);
            border-radius: 50%;
            border-top-color: #fff;
            animation: spin 1s ease-in-out infinite;
            margin-right: 8px;
        }

        @keyframes spin {
            to {
                transform: rotate(360deg);
            }
        }

        /* Toast custom styles */
        .custom-toast {
            background-color: #28a745;
            color: white;
            padding: 15px 30px;
            border-radius: 12px;
            font-size: 16px;
            text-align: center;
            box-shadow: 0 8px 20px rgba(0, 0, 0, 0.2);
            opacity: 0;
        }

        .toast-error {
            background-color: #ff5252;
            color: white;
            padding: 15px 30px;
            border-radius: 12px;
            font-size: 16px;
            text-align: center;
            box-shadow: 0 8px 20px rgba(0, 0, 0, 0.2);
            opacity: 0;
        }

        /* Responsive styles */
        @media (max-width: 768px) {
            .container {
                padding: 20px 15px;
            }

            .checkout-content {
                padding: 25px;
            }

            .form-group {
                flex: 1 0 100%;
                margin-bottom: 25px;
            }

            .checkout-progress {
                max-width: 100%;
            }

            .step-label {
                font-size: 12px;
            }

            .checkout-actions {
                flex-direction: column;
                gap: 15px;
            }

            .checkout-actions .btn {
                width: 100%;
            }

            .modal-content {
                margin: 10% auto;
                width: 95%;
                padding: 25px;
            }

            .address-list {
                grid-template-columns: 1fr;
            }
        }
    </style>
</head>

<body>
    <div class="container">
        <div class="checkout-header">
            <h1>Checkout</h1>

            <div class="checkout-progress">
                <div class="progress-bar">
                    <div class="step active">
                        <div class="step-icon">1</div>
                        <div class="step-label">Shipping</div>
                    </div>
                    <div class="step">
                        <div class="step-icon">2</div>
                        <div class="step-label">Payment</div>
                    </div>
                    <div class="step">
                        <div class="step-icon">3</div>
                        <div class="step-label">Confirmation</div>
                    </div>
                </div>
            </div>
        </div>

        <div class="checkout-content">
            <h2 class="section-title">
                <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none"
                    stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"></path>
                    <circle cx="12" cy="10" r="3"></circle>
                </svg>
                Shipping Information
            </h2>

            <!-- Contact Information Section -->
            <div class="contact-info">
                <h3 class="section-title" style="font-size: 18px;">Contact Details</h3>

                <div class="form-row">
                    <div class="form-group">
                        <label class="form-label" for="fullName">Full Name*</label>
                        <input type="text" class="form-control" id="fullName" name="fullName">
                        <div class="error-message" id="fullNameError">Please enter your full name</div>
                    </div>
                    <div class="form-group">
                        <label class="form-label" for="phone">Phone Number*</label>
                        <input type="tel" class="form-control" id="phone" name="phone" maxlength="10">
                        <div class="error-message" id="phoneError">Please enter a valid phone number</div>
                    </div>
                </div>
            </div>

            <!-- Saved Addresses Section -->
            <div class="saved-addresses">
                <h3 class="section-title" style="font-size: 18px;">Select Shipping Address</h3>

                <div id="addressContainer">
                    <!-- Address cards will be loaded here -->
                    <% if (addresses && addresses.length> 0) { %>
                        <div class="address-list">
                            <% addresses.forEach(address=> { %>
                                <div class="address-card" data-address-id="<%= address._id %>">
                                    <div class="address-selector">
                                        <input type="radio" name="address" value="<%= address._id %>"
                                            <%=addresses.length===1 ? 'checked' : '' %>>
                                    </div>
                                    <div class="address-content">
                                        <span class="address-type <%= address.type %>">
                                            <%= address.type %>
                                        </span>
                                        
                                        
                                        <p class="address-details">
                                            <%= address.doorNo %>, <%= address.street %><br>
                                                    <%= address.city %>, <%= address.district %><br>
                                                            <%= address.postcode %>
                                        </p>
                                    </div>
                                </div>
                                <% }); %>
                        </div>
                        <% } else { %>
                            <div class="empty-addresses">
                                <div class="empty-icon">
                                    <svg xmlns="http://www.w3.org/2000/svg" width="60" height="60" viewBox="0 0 24 24"
                                        fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"
                                        stroke-linejoin="round">
                                        <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"></path>
                                        <circle cx="12" cy="10" r="3"></circle>
                                    </svg>
                                </div>
                                <p class="empty-text">No saved addresses found. Please add a new address to continue.
                                </p>
                            </div>
                            <% } %>
                </div>

                <button class="new-address-btn" id="newAddressBtn">
                    <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none"
                        stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <line x1="12" y1="5" x2="12" y2="19"></line>
                        <line x1="5" y1="12" x2="19" y2="12"></line>
                    </svg>
                    Add New Address
                </button>
            </div>

            <div class="checkout-actions">
                <a href="/cart" class="btn btn-outline">
                    <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none"
                        stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <line x1="19" y1="12" x2="5" y2="12"></line>
                        <polyline points="12 19 5 12 12 5"></polyline>
                    </svg>
                    Return to Cart
                </a>
                <button id="continueToPayment" class="btn btn-primary">
                    Continue to Payment
                    <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none"
                        stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <line x1="5" y1="12" x2="19" y2="12"></line>
                        <polyline points="12 5 19 12 12 19"></polyline>
                    </svg>
                </button>
            </div>
        </div>
    </div>

    <!-- Modal for new address -->
    <div id="addressModal" class="modal">
        <div class="modal-content">
            <span class="close-modal">&times;</span>
            <h2 class="modal-title">Add New Address</h2>

            <form id="addressForm">
                <input type="hidden" id="addressId" name="addressId">
                <input type="hidden" id="userid" name="userid" value="<%= userVer?._id %>">

                <div class="form-row">
                    <div class="form-group">
                        <label class="form-label" for="doorNo">Door Number*</label>
                        <input type="text" class="form-control" id="doorNo" name="doorNo">
                        <div class="error-message" id="doorNoError">Please enter a valid door number</div>
                    </div>
                    <div class="form-group">
                        <label class="form-label" for="street">Street*</label>
                        <input type="text" class="form-control" id="street" name="street">
                        <div class="error-message" id="streetError">Please enter your street address</div>
                    </div>
                </div>

                <div class="form-row">
                    <div class="form-group">
                        <label class="form-label" for="city">City*</label>
                        <input type="text" class="form-control" id="city" name="city">
                        <div class="error-message" id="cityError">Please enter your city</div>
                    </div>
                    <div class="form-group">
                        <label class="form-label" for="district">District*</label>
                        <input type="text" class="form-control" id="district" name="district">
                        <div class="error-message" id="districtError">Please enter your district</div>
                    </div>
                </div>

                <div class="form-row">
                    <div class="form-group">
                        <label class="form-label" for="postcode">Postcode*</label>
                        <input type="text" class="form-control" id="postcode" name="postcode" maxlength="6">
                        <div class="error-message" id="postcodeError">Please enter a valid 6-digit postcode</div>
                    </div>
                    <div class="form-group">
                        <label class="form-label">Address Type*</label>
                        <div class="radio-container">
                            <div class="radio-option">
                                <input type="radio" name="type" id="typeHome" value="Home" checked>
                                <label for="typeHome">Home</label>
                            </div>
                            <div class="radio-option">
                                <input type="radio" name="type" id="typeOffice" value="Office">
                                <label for="typeOffice">Office</label>
                            </div>
                            <div class="radio-option">
                                <input type="radio" name="type" id="typeOther" value="Other">
                                <label for="typeOther">Other</label>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="save-address-row">
                    <label class="checkbox-container">
                        <input type="checkbox" id="isDefault" name="isDefault">
                        Set as default address
                    </label>
                </div>

                <div class="modal-footer">
                    <button type="button" class="btn btn-outline" id="cancelAddress">Cancel</button>
                    <button type="submit" class="btn btn-primary" id="saveAddressBtn">Save Address</button>
                </div>
            </form>
        </div>
    </div>
    <%- include("../../views/partials/user/footers") %>
    <!-- Toast Notification JS -->
    <script src="https://cdn.jsdelivr.net/npm/toastify-js"></script>
    <script>
        document.addEventListener('DOMContentLoaded', function () {
            // Form elements
            const fullNameInput = document.getElementById('fullName');
            const phoneInput = document.getElementById('phone');

            // Modal elements
            const modal = document.getElementById("addressModal");
            const newAddressBtn = document.getElementById("newAddressBtn");
            const closeModalBtn = document.querySelector(".close-modal");
            const cancelAddressBtn = document.getElementById("cancelAddress");

            // // Form elements in modal
            const doorNoInput = document.getElementById('doorNo');
            const streetInput = document.getElementById('street');
            const cityInput = document.getElementById('city');
            const districtInput = document.getElementById('district');
            const postcodeInput = document.getElementById('postcode');
            const saveAddressBtn = document.getElementById('saveAddressBtn');

            // Address selection
            const addressCards = document.querySelectorAll('.address-card');
            const continueBtn = document.getElementById('continueToPayment');

            // Validation functions
            function validateName(name) {
                return name.trim().length >= 3 && /^[a-zA-Z\s]+$/.test(name.trim());
            }

            function validatePhone(phone) {
                return /^[0-9]{10}$/.test(phone.trim());
            }

            function validateDoorNo(doorNo) {
                return doorNo.trim().length > 0;
            }

            function validateStreet(street) {
                return street.trim().length >= 3;
            }

            function validateCity(city) {
                return city.trim().length >= 2 && /^[a-zA-Z\s]+$/.test(city.trim());
            }

            function validateDistrict(district) {
                return district.trim().length >= 2 && /^[a-zA-Z\s]+$/.test(district.trim());
            }

            function validatePostcode(postcode) {
                return /^[0-9]{6}$/.test(postcode.trim());
            }

            // Show error message
            function showError(inputElement, errorElement, message) {
                inputElement.classList.add('error');
                errorElement.textContent = message;
                errorElement.classList.add('show');
            }

            // Hide error message
            function hideError(inputElement, errorElement) {
                inputElement.classList.remove('error');
                errorElement.classList.remove('show');
            }

            // Open modal
            newAddressBtn.addEventListener('click', function () {
                modal.style.display = "block";
               
            });

            // Close modal
            function closeModal() {
                modal.style.display = "none";
                document.getElementById('addressForm').reset();

                // Clear validation states
                const inputs = modal.querySelectorAll('.form-control');
                const errorElements = modal.querySelectorAll('.error-message');

                inputs.forEach(input => {
                    input.classList.remove('error');
                });

                errorElements.forEach(error => {
                    error.classList.remove('show');
                });
            }

            closeModalBtn.addEventListener('click', closeModal);
            cancelAddressBtn.addEventListener('click', closeModal);

            // Close modal when clicking outside
            window.addEventListener('click', function (event) {
                if (event.target == modal) {
                    closeModal();
                }
            });

            // Address card selection
            if (addressCards.length > 0) {
                addressCards.forEach(card => {
                    card.addEventListener('click', function () {
                        // Remove selected class from all cards
                        addressCards.forEach(c => c.classList.remove('selected'));
                        // Add selected class to clicked card
                        this.classList.add('selected');
                        // Check the radio button
                        const radio = this.querySelector('input[type="radio"]');
                        radio.checked = true;

                        // Get the name and phone from the selected address and populate the contact info section
                        const addressId = this.getAttribute('data-address-id');
                        const name = document.getElementById('addressName' + addressId).textContent.trim();
                        const phone = document.getElementById('addressPhone' + addressId).textContent.trim();

                        fullNameInput.value = name;
                        phoneInput.value = phone !== 'No phone provided' ? phone : '';
                    });
                });

                // Select the first address by default
                if (addressCards.length > 0 && !document.querySelector('.address-card.selected')) {
                    addressCards[0].click();
                }
            }

            // Form validation for contact info
            fullNameInput.addEventListener('blur', function () {
                if (!validateName(this.value)) {
                    showError(this, document.getElementById('fullNameError'), 'Please enter a valid name (letters only)');
                } else {
                    hideError(this, document.getElementById('fullNameError'));
                }
            });

            phoneInput.addEventListener('blur', function () {
                if (!validatePhone(this.value)) {
                    showError(this, document.getElementById('phoneError'), 'Please enter a valid 10-digit phone number');
                } else {
                    hideError(this, document.getElementById('phoneError'));
                }
            });

            doorNoInput.addEventListener('blur', function () {
                if (!validateDoorNo(this.value)) {
                    showError(this, document.getElementById('doorNoError'), 'Please enter a valid door number');
                } else {
                    hideError(this, document.getElementById('doorNoError'));
                }
            });

            streetInput.addEventListener('blur', function () {
                if (!validateStreet(this.value)) {
                    showError(this, document.getElementById('streetError'), 'Please enter a valid street name');
                } else {
                    hideError(this, document.getElementById('streetError'));
                }
            });

            cityInput.addEventListener('blur', function () {
                if (!validateCity(this.value)) {
                    showError(this, document.getElementById('cityError'), 'Please enter a valid city name (letters only)');
                } else {
                    hideError(this, document.getElementById('cityError'));
                }
            });

            districtInput.addEventListener('blur', function () {
                if (!validateDistrict(this.value)) {
                    showError(this, document.getElementById('districtError'), 'Please enter a valid district name (letters only)');
                } else {
                    hideError(this, document.getElementById('districtError'));
                }
            });

            postcodeInput.addEventListener('blur', function () {
                if (!validatePostcode(this.value)) {
                    showError(this, document.getElementById('postcodeError'), 'Please enter a valid 6-digit pincode');
                } else {
                    hideError(this, document.getElementById('postcodeError'));
                }
            });

            // Save new address
            document.getElementById('addressForm').addEventListener('submit', async function (e) {
                e.preventDefault();

                // Validate all fields before submission
                let isValid = true;

            

                if (!validateDoorNo(doorNoInput.value)) {
                    showError(doorNoInput, document.getElementById('doorNoError'), 'Please enter a valid door number');
                    isValid = false;
                }

                if (!validateStreet(streetInput.value)) {
                    showError(streetInput, document.getElementById('streetError'), 'Please enter a valid street name (at least 3 characters)');
                    isValid = false;
                }

                if (!validateCity(cityInput.value)) {
                    showError(cityInput, document.getElementById('cityError'), 'Please enter a valid city name (letters only)');
                    isValid = false;
                }

                if (!validateDistrict(districtInput.value)) {
                    showError(districtInput, document.getElementById('districtError'), 'Please enter a valid district name (letters only)');
                    isValid = false;
                }

                if (!validatePostcode(postcodeInput.value)) {
                    showError(postcodeInput, document.getElementById('postcodeError'), 'Please enter a valid 6-digit pincode');
                    isValid = false;
                }

                if (!isValid) {
                    return;
                }

                // Show loading state on button
                const saveButton = document.getElementById('saveAddressBtn');
                const originalButtonText = saveButton.innerHTML;
                saveButton.innerHTML = '<div class="loading"></div> Saving...';
                saveButton.disabled = true;

                const formData = {
                    doorNo: doorNoInput.value,
                    street: streetInput.value,
                    city: cityInput.value,
                    district: districtInput.value,
                    postcode: postcodeInput.value,
                    type: document.querySelector('input[name="type"]:checked').value,
                    isDefault: document.getElementById('isDefault').checked,
                    userId: document.getElementById('userid').value
                };

                try {
                    const response = await fetch('/addAddress', {
                        method: 'POST',
                        headers: {
                            'Content-Type': 'application/json',
                        },
                        body: JSON.stringify(formData)
                    });

                    const result = await response.json();

                    if (response.ok) {
                        Toastify({
                            text: "Address saved successfully!",
                            duration: 3000,
                            className: "custom-toast",
                            close: true,
                            gravity: "top",
                            position: "right",
                        }).showToast();

                        // Reload the page to show the new address
                        setTimeout(() => {
                            window.location.reload();
                        }, 1000);
                    } else {
                        throw new Error(result.message || 'Failed to save address');
                    }
                } catch (error) {
                    Toastify({
                        text: error.message,
                        duration: 3000,
                        className: "custom-toast toast-error",
                        close: true,
                        gravity: "top",
                        position: "right",
                    }).showToast();

                    // Reset button state
                    saveButton.innerHTML = originalButtonText;
                    saveButton.disabled = false;
                }
            });

            // Continue to payment
            continueBtn.addEventListener('click', async function () {
                // Validate contact information
                let isValid = true;

                if (!validateName(fullNameInput.value)) {
                    showError(fullNameInput, document.getElementById('fullNameError'), 'Please enter a valid name (at least 3 characters, letters only)');
                    isValid = false;
                }

                if (!validatePhone(phoneInput.value)) {
                    showError(phoneInput, document.getElementById('phoneError'), 'Please enter a valid 10-digit phone number');
                    isValid = false;
                }

                if (!isValid) {
                    Toastify({
                        text: "Please fill in all required fields correctly",
                        duration: 3000,
                        className: "custom-toast toast-error",
                        close: true,
                        gravity: "top",
                        position: "right",
                    }).showToast();
                    return;
                }

                const selectedAddress = document.querySelector('input[name="address"]:checked');

                if (!selectedAddress) {
                    Toastify({
                        text: "Please select a shipping address",
                        duration: 3000,
                        className: "custom-toast toast-error",
                        close: true,
                        gravity: "top",
                        position: "right",
                    }).showToast();
                    return;
                }

                // Show loading state
                const originalButtonText = continueBtn.innerHTML;
                continueBtn.innerHTML = '<div class="loading"></div> Processing...';
                continueBtn.disabled = true;

                try {
                    const response = await fetch('/checkout', {
                        method: 'POST',
                        headers: {
                            'Content-Type': 'application/json',
                        },
                        body: JSON.stringify({
                            name: fullNameInput.value,
                            phone: phoneInput.value,
                            address: selectedAddress.value
                        })
                    });

                    if (response.ok) {
                        window.location.href = '/payment';
                    } else {
                        const result = await response.json();
                        throw new Error(result.message || 'Failed to proceed to payment');
                    }
                } catch (error) {
                    Toastify({
                        text: error.message,
                        duration: 3000,
                        className: "custom-toast toast-error",
                        close: true,
                        gravity: "top",
                        position: "right",
                    }).showToast();

                    // Reset button state
                    continueBtn.innerHTML = originalButtonText;
                    continueBtn.disabled = false;
                }
            });
        });
    </script>