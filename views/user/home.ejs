      <div class="section-title text-center mb-5">
        <h2>Featured Products</h2>
        <p>Our most popular audio equipment</p>
      </div>
      <div class="row">

        <div class="products-grid">
          <% if (products.length> 0) { %>
            <% products.forEach(product=> { %>
              <div class="product-card">
                <a href="/product/<%= product._id %>" style="text-decoration: none; color: inherit;">
                  <div class="product-image">
                    <img src="<%= product.productImage1 %>" alt="<%= product.productName %>">
                  </div>
                  <div class="product-info">
                    <h3 class="product-title">
                      <%= product.productName %>
                    </h3>
                    <div class="product-price">
                      <span class="current-price">₹<%= product.productOfferPrice || product.productPrice %></span>
                      <% if (product.productOfferPrice) { %>
                        <span class="original-price">₹<%= product.productPrice %></span>
                        <% } %>
                    </div>
                  </div>
                </a>
                
              </div>
              <% }); %>
                <% } else { %>
                  <div class="no-products">
                    <h3>No products found</h3>
                    <p>Try adjusting your filters or search terms</p>
                  </div>
                  <% } %>
        </div>
      </div>

    </div>
    <div class="text-center mt-4">
      <a href="/shop" class="btn btn-lg btn-outline-primary">View All Products</a>
    </div>
    </div>
  </section>

