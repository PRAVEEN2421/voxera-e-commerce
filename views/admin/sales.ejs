<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Sales Report | Admin</title>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <style>
        :root {
            --primary-color: #4361ee;
            --secondary-color: #3f37c9;
            --accent-color: #4cc9f0;
            --light-color: #f8f9fa;
            --dark-color: #212529;
            --success-color: #4bb543;
            --danger-color: #ff3333;
        }

        body {
            background-color: #f5f7fa;
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
        }

        .card {
            border-radius: 10px;
            box-shadow: 0 4px 6px rgba(0, 0, 0, 0.05);
            border: none;
            transition: transform 0.3s, box-shadow 0.3s;
        }

        .card:hover {
            transform: translateY(-5px);
            box-shadow: 0 10px 20px rgba(0, 0, 0, 0.1);
        }

        .card-title {
            color: var(--secondary-color);
            font-weight: 600;
        }

        .filter-section {
            background: white;
            border-radius: 10px;
            padding: 1.5rem;
            box-shadow: 0 4px 6px rgba(0, 0, 0, 0.05);
            margin-bottom: 2rem;
        }

        .table-responsive {
            border-radius: 10px;
            overflow: hidden;
            box-shadow: 0 4px 6px rgba(0, 0, 0, 0.05);
        }

        .table thead {
            background-color: var(--primary-color);
            color: white;
        }

        .table th {
            padding: 1rem;
            font-weight: 500;
        }

        .table td {
            vertical-align: middle;
        }

        .badge {
            padding: 0.5em 0.75em;
            font-weight: 500;
        }

        .btn-primary {
            background-color: var(--primary-color);
            border-color: var(--primary-color);
        }

        .btn-primary:hover {
            background-color: var(--secondary-color);
            border-color: var(--secondary-color);
        }

        .btn-outline-danger {
            color: var(--danger-color);
            border-color: var(--danger-color);
        }

        .btn-outline-danger:hover {
            background-color: var(--danger-color);
            color: white;
        }

        .toast {
            position: fixed;
            top: 20px;
            right: 20px;
            z-index: 9999;
            padding: 1rem;
            border-radius: 8px;
            color: white;
            display: none;
            animation: fadeIn 0.5s;
        }

        .toast.success {
            background-color: var(--success-color);
        }

        .toast.error {
            background-color: var(--danger-color);
        }

        @keyframes fadeIn {
            from {
                opacity: 0;
                transform: translateY(-20px);
            }

            to {
                opacity: 1;
                transform: translateY(0);
            }
        }

        .empty-state {
            padding: 3rem;
            text-align: center;
        }

        .empty-state i {
            font-size: 3rem;
            color: #adb5bd;
            margin-bottom: 1rem;
        }
    </style>
</head>

<body>
    <%- include('../partials/admin/header') %>

        <div class="container py-4">
            <div class="d-flex justify-content-between align-items-center mb-4">
                <h2 class="mb-0">Sales Report</h2>
                <div>
                    <button class="btn btn-primary me-2" onclick="downloadReport('pdf')">
                        <i class="fas fa-file-pdf me-2"></i>PDF
                    </button>
                    <button class="btn btn-success" onclick="downloadReport('excel')">
                        <i class="fas fa-file-excel me-2"></i>Excel
                    </button>
                </div>
            </div>

            <!-- Summary Cards -->
            <div class="row mb-4">
                <div class="col-md-6 mb-3 mb-md-0">
                    <div class="card h-100">
                        <div class="card-body text-center">
                            <h5 class="card-title">Total Sales</h5>
                            <p class="display-5 fw-bold text-primary">₹<%=salesData.totalAmount.toLocaleString() %>
                            </p>
                        </div>
                    </div>
                </div>
                <div class="col-md-6">
                    <div class="card h-100">
                        <div class="card-body text-center">
                            <h5 class="card-title">Total Discount</h5>
                            <p class="display-5 fw-bold text-success">₹<%= salesData.totalDiscount.toLocaleString() %>
                            </p>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Filter Section -->
            <div class="filter-section">
                <div class="row g-3">
                    <div class="col-md-5">
                        <form id="dateFilterForm" class="row g-2 align-items-end">
                            <div class="col-md-5">
                                <label class="form-label">From Date</label>
                                <input type="date" class="form-control" id="startDate" name="startDate"
                                    value="<%= filters?.startDate %>"
                                    max="<%= new Date().toISOString().split('T')[0] %>">
                            </div>
                            <div class="col-md-5">
                                <label class="form-label">To Date</label>
                                <input type="date" class="form-control" id="endDate" name="endDate"
                                    value="<%= filters?.endDate %>" max="<%= new Date().toISOString().split('T')[0] %>">
                            </div>
                            <div class="col-md-2">
                                <button type="submit" class="btn btn-primary w-100">Apply</button>
                            </div>
                        </form>
                    </div>

                    <div class="col-md-5">
                        <form id="periodFilterForm" class="row g-2 align-items-end">
                            <div class="col-md-7">
                                <label class="form-label">Quick Period</label>
                                <select class="form-select" id="timePeriod" name="timePeriod">
                                    <option value="" <%=!filters?.timePeriod ? 'selected' : '' %>>Select Period</option>
                                    <option value="week" <%=filters?.timePeriod==='week' ? 'selected' : '' %>>Last Week
                                    </option>
                                    <option value="month" <%=filters?.timePeriod==='month' ? 'selected' : '' %>>Last
                                        Month</option>
                                    <option value="year" <%=filters?.timePeriod==='year' ? 'selected' : '' %>>Last Year
                                    </option>
                                </select>
                            </div>
                            <div class="col-md-5">
                                <button type="submit" class="btn btn-primary w-100">Filter</button>
                            </div>
                        </form>
                    </div>

                    <div class="col-md-2 d-flex align-items-end">
                        <button id="clearFilters" class="btn btn-outline-danger w-100">
                            <i class="fas fa-times me-2"></i>Clear
                        </button>
                    </div>
                </div>
            </div>

            <!-- Sales Table -->
            <div class="table-responsive">
                <table class="table table-hover">
                    <thead>
                        <tr>
                            <th>#</th>
                            <th>Order ID</th>
                            <th>Customer</th>
                            <th>Date</th>
                            <th>Items</th>
                            <th>Amount</th>
                            <th>Payment</th>
                        </tr>
                    </thead>
                    <tbody>
                        <% if (orders.length> 0) { %>
                            <% orders.forEach((order, index)=> { %>
                                <tr>
                                    <td>
                                        <%= index + 1 %>
                                    </td>
                                    <td>#<%= order.orderId %>
                                    </td>
                                    <td>
                                        <%= order.fullName %>
                                    </td>
                                    <td>
                                        <%= new Date(order.deliveryDate).toLocaleDateString() %>
                                    </td>
                                    <td><span class="badge bg-primary">
                                            <%= order.products.length %>
                                        </span></td>
                                    <td>₹<%= order.priceDetails.total.toLocaleString() %>
                                    </td>
                                    <td>
                                        <span
                                            class="badge <%= order.paymentMethod === 'COD' ? 'bg-warning text-dark' : 'bg-success' %>">
                                            <%= order.paymentMethod %>
                                        </span>
                                    </td>
                                </tr>
                                <% }); %>
                                    <% } else { %>
                                        <tr>
                                            <td colspan="7">
                                                <div class="empty-state">
                                                    <i class="fas fa-chart-line"></i>
                                                    <h4>No orders found</h4>
                                                    <p class="text-muted">Try adjusting your filters or check back later
                                                    </p>
                                                </div>
                                            </td>
                                        </tr>
                                        <% } %>
                    </tbody>
                </table>
            </div>
        </div>

        <div id="toast" class="toast"></div>

        <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
        <script>
            // Initialize date relationships
            document.addEventListener('DOMContentLoaded', () => {
                const startDate = document.getElementById('startDate');
                const endDate = document.getElementById('endDate');

                startDate.addEventListener('change', () => {
                    endDate.min = startDate.value;
                    if (new Date(endDate.value) < new Date(startDate.value)) {
                        endDate.value = startDate.value;
                    }
                });

                endDate.addEventListener('change', () => {
                    startDate.max = endDate.value;
                });
            });

            // Date filter form submission
            document.getElementById('dateFilterForm').addEventListener('submit', async (e) => {
                e.preventDefault();

                const startDate = document.getElementById('startDate').value;
                const endDate = document.getElementById('endDate').value;

                if (!startDate || !endDate) {
                    showToast('Please select both dates', 'error');
                    return;
                }

                try {
                    const response = await fetch('/admin/sales/filter/date', {
                        method: 'POST',
                        headers: { 'Content-Type': 'application/json' },
                        body: JSON.stringify({ startDate, endDate })
                    });

                    if (response.ok) {
                        window.location.reload();
                    } else {
                        showToast('Failed to apply date filter', 'error');
                    }
                } catch (error) {
                    console.error('Error:', error);
                    showToast('Network error', 'error');
                }
            });

            // Period filter form submission
            document.getElementById('periodFilterForm').addEventListener('submit', async (e) => {
                e.preventDefault();

                const timePeriod = document.getElementById('timePeriod').value;

                if (!timePeriod) {
                    showToast('Please select a time period', 'error');
                    return;
                }

                try {
                    const response = await fetch('/admin/sales/filter/period', {
                        method: 'POST',
                        headers: { 'Content-Type': 'application/json' },
                        body: JSON.stringify({ timePeriod })
                    });

                    if (response.ok) {
                        window.location.reload();
                    } else {
                        showToast('Failed to apply period filter', 'error');
                    }
                } catch (error) {
                    console.error('Error:', error);
                    showToast('Network error', 'error');
                }
            });

            // Clear filters
            document.getElementById('clearFilters').addEventListener('click', async () => {
                try {
                    const response = await fetch('/admin/sales/filter/clear', {
                        method: 'POST'
                    });

                    if (response.ok) {
                        window.location.reload();
                    } else {
                        showToast('Failed to clear filters', 'error');
                    }
                } catch (error) {
                    console.error('Error:', error);
                    showToast('Network error', 'error');
                }
            });

            function downloadReport(type) {
                const btn = type === 'pdf'
                    ? document.querySelector('button[onclick*="pdf"]')
                    : document.querySelector('button[onclick*="excel"]');


                fetch(`/admin/sales/report/${type}`)
                    .then(response => {
                        if (!response.ok) throw new Error('Failed to download');
                        return response.blob();
                    })
                    .then(blob => {
                        // Create download link
                        const url = window.URL.createObjectURL(blob);
                        const a = document.createElement('a');
                        a.style.display = 'none';
                        a.href = url;
                        a.download = `sales_report.${type === 'pdf' ? 'pdf' : 'xlsx'}`;
                        document.body.appendChild(a);
                        a.click();

                        // Cleanup
                        window.URL.revokeObjectURL(url);
                        document.body.removeChild(a);
                    })
                    .catch(error => {
                        console.error('Download error:', error);
                        showToast('Failed to download report', 'error');
                    })
                    .finally(() => {
                        btn.innerHTML = originalText;
                        btn.disabled = false;
                    });
            }
            // Toast notification
            function showToast(message, type = 'success') {
                const toast = document.getElementById('toast');
                toast.textContent = message;
                toast.className = `toast ${type}`;
                toast.style.display = 'block';

                setTimeout(() => {
                    toast.style.display = 'none';
                }, 3000);
            }
        </script>
</body>

</html>