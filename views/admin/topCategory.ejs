<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Top Selling Categories</title>
    <link rel="icon" href="/images/logo.png">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Afacad+Flux:wght@100..1000&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css">
    <style>
        * {
            font-family: "Afacad Flux", serif;
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            background-color: #f8f9fa;
            color: #333;
        }

        .page-header {
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            color: white;
            padding: 3rem 0;
            margin-bottom: 2rem;
            text-align: center;
            box-shadow: 0 4px 6px rgba(0,0,0,0.1);
        }

        .page-title {
            font-size: 2.5rem;
            font-weight: 700;
            margin: 0;
            text-shadow: 2px 2px 4px rgba(0,0,0,0.3);
        }

        .page-subtitle {
            font-size: 1.2rem;
            font-weight: 300;
            margin-top: 0.5rem;
            opacity: 0.9;
        }

        .table-container {
            background: white;
            border-radius: 12px;
            box-shadow: 0 8px 25px rgba(0,0,0,0.1);
            overflow: hidden;
            margin: 2rem auto;
            max-width: 800px;
        }

        .table {
            margin: 0;
            font-size: 1.1rem;
        }

        .table thead th {
            background: linear-gradient(135deg, #2c3e50 0%, #34495e 100%);
            color: white;
            padding: 1.2rem;
            font-weight: 600;
            border: none;
            text-transform: uppercase;
            letter-spacing: 0.5px;
            font-size: 0.95rem;
        }

        .table tbody td {
            padding: 1rem 1.2rem;
            border-color: #e9ecef;
            vertical-align: middle;
        }

        .table tbody tr {
            transition: all 0.3s ease;
        }

        .table tbody tr:hover {
            background-color: #f8f9ff;
            transform: translateY(-1px);
            box-shadow: 0 4px 8px rgba(0,0,0,0.05);
        }

        .table tbody tr:nth-child(even) {
            background-color: #f8f9fa;
        }

        .rank-badge {
            display: inline-flex;
            align-items: center;
            justify-content: center;
            width: 40px;
            height: 40px;
            border-radius: 50%;
            font-weight: 700;
            color: white;
            font-size: 1.1rem;
        }

        .rank-1 { background: linear-gradient(135deg, #FFD700, #FFA500); }
        .rank-2 { background: linear-gradient(135deg, #C0C0C0, #A0A0A0); }
        .rank-3 { background: linear-gradient(135deg, #CD7F32, #B8860B); }
        .rank-other { background: linear-gradient(135deg, #6c757d, #5a6268); }

        .category-name {
            font-weight: 600;
            color: #2c3e50;
            font-size: 1.1rem;
        }

        .products-count {
            font-weight: 700;
            color: #27ae60;
            font-size: 1.2rem;
        }

        .container {
            padding: 0 1rem;
        }

        @media (max-width: 768px) {
            .page-title {
                font-size: 2rem;
            }
            
            .table-container {
                margin: 1rem;
                border-radius: 8px;
            }
            
            .table thead th,
            .table tbody td {
                padding: 0.8rem 0.6rem;
                font-size: 0.95rem;
            }
            
            .rank-badge {
                width: 35px;
                height: 35px;
                font-size: 1rem;
            }
        }
    </style>
</head>
<body>
    <%- include("../../views/partials/admin/header") %>
    
    
    
    <div class="container">
        <div class="table-container">
            <table class="table table-hover">
                <thead>
                    <tr>
                        <th width="15%">Rank</th>
                        <th width="50%">Category Name</th>
                        <th width="35%">Total Products Sold</th>
                    </tr>
                </thead>
                <tbody>
                    <% categoryRevenueData.forEach((category, index) => { %>
                        <tr>
                            <td>
                                <span class="rank-badge <%= index === 0 ? 'rank-1' : index === 1 ? 'rank-2' : index === 2 ? 'rank-3' : 'rank-other' %>">
                                    <%= index + 1 %>
                                </span>
                            </td>
                            <td class="category-name"><%= category.categoryName %></td>
                            <td class="products-count"><%= category.totalProducts.toLocaleString() %></td>
                        </tr>
                    <% }); %>                
                </tbody>
            </table>
        </div>
    </div>
    
</body>
</html>