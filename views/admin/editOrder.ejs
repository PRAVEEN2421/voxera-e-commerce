<%- include("../../views/partials/admin/header") %>

    <style>
        :root {
            --primary-color: #00f2ea;
            --primary-dark: #00d6d0;
            --text-dark: #333;
            --text-light: #666;
            --border-color: #eee;
            --bg-light: #fafafa;
            --bg-white: #ffffff;
            --shadow: 0 4px 12px rgba(0, 0, 0, 0.05);
            --radius: 12px;
            --radius-sm: 8px;
            --spacing-sm: 10px;
            --spacing-md: 20px;
            --spacing-lg: 30px;
            --danger-color: #ff5252;
            --danger-dark: #d32f2f;
            --success-color: #28a745;
            --warning-color: #ffc107;
            --warning-dark: #e0a800;
        }

        * {
            box-sizing: border-box;
            margin: 0;
            padding: 0;
        }

        body {
            font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Oxygen, Ubuntu, Cantarell, 'Open Sans', 'Helvetica Neue', sans-serif;
            background-color: var(--bg-light);
            color: var(--text-dark);
            line-height: 1.6;
        }

        .page-content {
            width: 100%;
            max-width: 1200px;
            margin: 0 auto;
            padding: 20px;
        }

        .back-button {
            display: inline-flex;
            align-items: center;
            margin-bottom: 20px;
            color: var(--text-dark);
            text-decoration: none;
            font-weight: 500;
            transition: all 0.2s ease;
        }

        .back-button:hover {
            color: var(--primary-color);
        }

        .back-button svg {
            margin-right: 8px;
        }

        .order-details-container {
            background-color: var(--bg-white);
            border-radius: var(--radius);
            box-shadow: var(--shadow);
            padding: 30px;
            margin-bottom: 30px;
        }

        .order-header {
            display: flex;
            justify-content: space-between;
            align-items: flex-start;
            margin-bottom: 30px;
            flex-wrap: wrap;
            gap: 20px;
        }

        .order-title {
            font-size: 24px;
            font-weight: 700;
            margin-bottom: 8px;
        }

        .order-id {
            font-size: 16px;
            color: var(--text-light);
            margin-bottom: 4px;
        }

        .order-date {
            font-size: 14px;
            color: var(--text-light);
        }

        .order-status {
            padding: 6px 14px;
            border-radius: 20px;
            font-size: 14px;
            font-weight: 500;
            display: inline-block;
        }

        .status-pending, .status-ordered {
            background-color: #fff8e1;
            color: #ff8f00;
        }

        .status-processing {
            background-color: #fff4e5;
            color: #ff8800;
        }

        .status-shipped {
            background-color: #e6f6ff;
            color: #0085ff;
        }

        .status-delivered {
            background-color: #e3f9e5;
            color: #1b873d;
        }

        .status-cancelled {
            background-color: #ffebee;
            color: #d32f2f;
        }

        .status-returnprocessing {
            background-color: #f3e5f5;
            color: #9c27b0;
        }

        .status-returned {
            background-color: #e8eaf6;
            color: #3f51b5;
        }

        .info-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
            gap: 30px;
            margin-bottom: 30px;
        }

        .info-card {
            box-shadow: rgba(50, 50, 93, 0.25) 0px 50px 100px -20px, rgba(0, 0, 0, 0.3) 0px 30px 60px -30px, rgba(10, 37, 64, 0.35) 0px -2px 6px 0px inset;
            border-radius: var(--radius-sm);
            padding: 20px;
            background: #FFFF;
            background: radial-gradient(circle, rgba(255, 255, 255, 1) 0%, rgba(187, 253, 252, 0.72) 100%);
        }

        .info-title {
            font-size: 16px;
            font-weight: 600;
            margin-bottom: 15px;
            display: flex;
            align-items: center;
        }

        .info-title svg {
            margin-right: 8px;
        }

        .info-content {
            font-size: 14px;
            color: var(--text-dark);
        }

        .info-content p {
            margin-bottom: 6px;
        }

        .info-content p:last-child {
            margin-bottom: 0;
        }

        .product-table {
            width: 100%;
            border-collapse: collapse;
            margin-bottom: 30px;
        }

        .product-table th,
        .product-table td {
            padding: 15px;
            text-align: left;
            border-bottom: 1px solid var(--border-color);
        }

        .product-table th {
            font-weight: 600;
            color: var(--text-light);
            font-size: 14px;
            text-transform: uppercase;
            letter-spacing: 0.5px;
        }

        .product-table tr:last-child td {
            border-bottom: none;
        }

        .product-image {
            width: 60px;
            height: 60px;
            object-fit: cover;
            border-radius: var(--radius-sm);
            background-color: #f5f5f5;
        }

        .product-name {
            font-weight: 500;
        }

        .summary-section {
            display: flex;
            justify-content: flex-end;
            margin-bottom: 30px;
        }

        .order-summary {
            width: 100%;
            max-width: 400px;
        }

        .summary-row {
            display: flex;
            justify-content: space-between;
            padding: 10px 0;
            border-bottom: 1px solid var(--border-color);
        }

        .summary-row:last-child {
            border-bottom: none;
            font-weight: 700;
            font-size: 18px;
            padding-top: 15px;
        }

        .status-controls {
            display: flex;
            gap: 15px;
            align-items: center;
        }

        .status-selector {
            padding: 10px 15px;
            border-radius: var(--radius-sm);
            border: 1px solid var(--border-color);
            font-size: 14px;
            background-color: white;
            cursor: pointer;
        }

        .status-selector:focus {
            outline: none;
            border-color: var(--primary-color);
        }

        .action-buttons, .return-actions {
            display: flex;
            gap: 15px;
            flex-wrap: wrap;
        }

        .button {
            display: inline-flex;
            align-items: center;
            justify-content: center;
            padding: 12px 24px;
            border-radius: var(--radius-sm);
            font-size: 16px;
            font-weight: 500;
            text-decoration: none;
            cursor: pointer;
            transition: all 0.2s ease;
            border: none;
            box-shadow: rgba(13, 13, 21, 0.25) 0px 50px 100px -20px, rgba(0, 0, 0, 0.3) 0px 30px 60px -30px, rgba(10, 37, 64, 0.35) 0px -2px 6px 0px inset;
        }

        .button svg {
            margin-right: 8px;
        }

        .primary-button {
            background-color: var(--primary-color);
            color: #000;
        }

        .primary-button:hover {
            background-color: var(--primary-dark);
            transform: translateY(-2px);
            box-shadow: 0 4px 8px rgba(0, 0, 0, 0.1);
        }

        .approve-btn {
            background-color: var(--success-color);
            color: white;
        }

        .approve-btn:hover {
            background-color: #218838;
            transform: translateY(-2px);
            box-shadow: 0 4px 8px rgba(0, 0, 0, 0.1);
        }

        .reject-btn {
            background-color: var(--danger-color);
            color: white;
        }

        .reject-btn:hover {
            background-color: var(--danger-dark);
            transform: translateY(-2px);
            box-shadow: 0 4px 8px rgba(0, 0, 0, 0.1);
        }

        .return-section {
            margin: 20px 0;
            padding: 20px;
            background-color: #f8f9fa;
            border-radius: 8px;
            border-left: 4px solid #34495e;
        }

        .return-reason {
            background-color: white;
            padding: 15px;
            border-radius: 6px;
            margin-bottom: 15px;
        }

        .return-reason h4 {
            margin-top: 0;
            color: #7f8c8d;
            font-size: 16px;
        }

        .return-reason p {
            margin-bottom: 0;
            color: #333;
        }

        /* Toast Notification Styles */
        .swal2-popup {
            font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Oxygen, Ubuntu, Cantarell, 'Open Sans', 'Helvetica Neue', sans-serif;
            padding: 1.5em;
            border-radius: var(--radius);
            box-shadow: var(--shadow);
        }

        .swal2-title {
            font-size: 1.2em;
            font-weight: 600;
            color: var(--text-dark);
        }

        .swal2-icon {
            margin: 1em auto 0.5em;
        }

        .swal2-styled.swal2-confirm {
            background-color: var(--primary-color);
            color: #000;
            padding: 0.6em 1.5em;
            border-radius: var(--radius-sm);
            font-weight: 500;
            box-shadow: rgba(13, 13, 21, 0.25) 0px 50px 100px -20px, rgba(0, 0, 0, 0.3) 0px 30px 60px -30px, rgba(10, 37, 64, 0.35) 0px -2px 6px 0px inset;
        }

        .swal2-styled.swal2-confirm:hover {
            background-color: var(--primary-dark);
            transform: translateY(-2px);
        }

        .swal2-styled.swal2-cancel {
            background-color: #f8f9fa;
            color: var(--text-dark);
            border: 1px solid var(--border-color);
        }

        /* Responsive styles */
        @media (max-width: 768px) {
            .order-header {
                flex-direction: column;
                align-items: flex-start;
                gap: 15px;
            }

            .product-table {
                display: block;
                overflow-x: auto;
            }

            .status-controls {
                flex-direction: column;
                align-items: flex-start;
                width: 100%;
            }

            .status-selector, .button {
                width: 100%;
            }

            .return-actions {
                flex-direction: column;
                width: 100%;
            }
        }
    </style>
<body>
    <div class="page-content">
        <a href="/admin/orders" class="back-button">
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none"
                stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <line x1="19" y1="12" x2="5" y2="12"></line>
                <polyline points="12 19 5 12 12 5"></polyline>
            </svg>
            Back to Orders
        </a>

        <div class="order-details-container">
            <div class="order-header">
                <div>
                    <h1 class="order-title">Order Details</h1>
                    <p class="order-id">Order ID: #<%= orderData.orderId %>
                    </p>
                    <p class="order-date">Placed on: <%= new Date(orderData.createdAt).toLocaleDateString() %>
                    </p>
                </div>
                <div class="status-controls">
                    <span class="order-status status-<%= orderData.status.toLowerCase().replace(' ', '') %>">
                        <%= orderData.status %>
                    </span>

                    <% if(orderData.status !=='Cancelled' && orderData.status !=='Return processing' && orderData.status
                        !=='Returned' ) { %>
                        <select class="status-selector" id="statusSelector">
                            <option value="Shipped" <%=orderData.status==='Shipped' ? 'selected' : '' %>>Shipped
                            </option>
                            <option value="Delivered" <%=orderData.status==='Delivered' ? 'selected' : '' %>>Delivered
                            </option>
                        </select>
                        <button class="button primary-button" id="updateStatusBtn">Update Status</button>
                        <% } %>
                </div>
            </div>

            <% if(orderData.status==='Return processing' || orderData.status==='Returned' ) { %>
                <div class="return-section">
                    <% if(orderData.returnReason) { %>
                        <div class="return-reason">
                            <h4>Return Reason</h4>
                            <p>
                                <%= orderData.returnReason %>
                            </p>
                        </div>
                        <% } %>

                            <% if(orderData.status==='Return processing' ) { %>
                                <div class="return-actions">
                                    <button class="button approve-btn" id="approveReturnBtn">Approve Return</button>
                                    <button class="button reject-btn" id="rejectReturnBtn">Reject Return</button>
                                </div>
                                <% } %>
                </div>
                <% } %>

                    <div class="info-grid">
                        <div class="info-card">
                            <h3 class="info-title">
                                <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24"
                                    fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"
                                    stroke-linejoin="round">
                                    <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"></path>
                                    <circle cx="12" cy="7" r="4"></circle>
                                </svg>
                                Customer Information
                            </h3>
                            <div class="info-content">
                                <p><strong>Name:</strong>
                                    <%= orderData.fullName %>
                                </p>
                                <p><strong>Email:</strong>
                                    <%= orderData.email %>
                                </p>
                                <p><strong>Phone:</strong>
                                    <%= orderData.phone %>
                                </p>
                            </div>
                        </div>

                        <div class="info-card">
                            <h3 class="info-title">
                                <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24"
                                    fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"
                                    stroke-linejoin="round">
                                    <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"></path>
                                    <circle cx="12" cy="10" r="3"></circle>
                                </svg>
                                Shipping Address
                            </h3>
                            <div class="info-content">
                                <p>DoorNo: <%= orderData.address.doorNo %>
                                </p>
                                <p>Street: <%= orderData.address.street %>, City: <%= orderData.address.city %>
                                </p>
                                <p>District: <%= orderData.address.district %>, Pincode: <%= orderData.address.pinCode
                                            %>
                                </p>
                            </div>
                        </div>

                        <div class="info-card">
                            <h3 class="info-title">
                                <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24"
                                    fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"
                                    stroke-linejoin="round">
                                    <rect x="1" y="4" width="22" height="16" rx="2" ry="2"></rect>
                                    <line x1="1" y1="10" x2="23" y2="10"></line>
                                </svg>
                                Payment Information
                            </h3>
                            <div class="info-content">
                                <p><strong>Payment Method:</strong>
                                    <%= orderData.paymentMethod %>
                                </p>
                                <p><strong>Payment Status:</strong>
                                   <% if(orderData.status==='Delivered' || orderData.status==='Return processing' || orderData.paymentMethod==='Wallet' ) { %>
                                    <span style="color: var(--success-color);">Paid</span>
                                    <% }  else if(orderData.status==='Ordered' && orderData.paymentMethod==='Razorpay' ) { %>
                                            <span style="color: var(--success-color);">Paid</span>
                                    <% } else if(orderData.status==='Ordered' &&
                                        orderData.paymentMethod==='Cash on delivery' ) { %>
                                        <span style="color: var(--warning-dark);">Pending</span>
                                        <% } else if(orderData.status==='Shipped' && orderData.paymentMethod==='Razorpay'  ) { %>
                                                <span style="color: var(--success-color);">Paid</span>
                                            <% } else if(orderData.status==='Shipped' && orderData.paymentMethod!=='Razorpay' ) { %>
                                                <span style="color: var(--warning-dark);">Pending</span>
                                                <% } else if(orderData.status==='Returned' ) { %>
                                                    <span style="color: var(--warning-dark);">Refunded</span>
                                                    <% } else { %>
                                                        <span style="color: var(--danger-color);">Failed</span>
                                                        <% } %>
                                </p>
                                <p><strong>Transaction ID:</strong>
                                    <%= orderData.transactionId || 'N/A' %>
                                </p>
                            </div>
                        </div>
                    </div>

                    <h2 style="margin-bottom: 20px;">Order Items</h2>

                    <div class="table-responsive">
                        <table class="product-table">
                            <thead>
                                <tr>
                                    <th>Product Name</th>
                                    <th>Price</th>
                                    <th>Quantity</th>
                                    <th>Status</th>
                                    <th>Total</th>
                                </tr>
                            </thead>
                            <tbody>
                                <% orderData.products.forEach(item=> { %>
                                    <tr>
                                        <td class="product-name">
                                            <%= item.productName %>
                                        </td>
                                        <td>₹<%= item.productPrice.toFixed(2) %>
                                        </td>
                                        <td>
                                            <%= item.quantity %>
                                        </td>
                                        <td>
                                            <span
                                                class="order-status status-<%= (item.status || orderData.status).toLowerCase().replace(' ', '') %>">
                                                <%= item.status || orderData.status %>
                                            </span>
                                        </td>
                                        <td>₹<%= (item.productPrice * item.quantity).toFixed(2) %>
                                        </td>
                                    </tr>
                                    <% }) %>
                            </tbody>
                        </table>
                    </div>

                    
                <div class="summary-section">
                    <div class="order-summary">
                        <div class="summary-row">
                            <span>Sub Total:</span>
                            <span>₹<%= orderData.priceDetails.subtotal.toFixed(2) %></span>
                        </div>

                        <% if(orderData.priceDetails.tax) { %>
                            <div class="summary-row">
                                <span>Tax:</span>
                                <span>₹<%= orderData.priceDetails.tax.toFixed(2) %></span>
                            </div>
                            <% } %>
                                <% if(orderData.priceDetails.couponDiscount) { %>
                                    <div class="summary-row">
                                        <span>Coupon:</span>
                                        <span style="color: green;">-₹<%=
                                                orderData.priceDetails.couponDiscount.toFixed(2) %></span>
                                    </div>
                                    <% }else{ %>
                                        <div class="summary-row">
                                            <span>Coupon:</span>
                                            <span>-₹0</span>
                                        </div>
                                        <% } %>
                                            <div class="summary-row">
                                                <span>Shipping Cost:</span>
                                                <span>Free</span>
                                            </div>
                                            <div class="summary-row">
                                                <span>Grand Total:</span>
                                                <span>₹<%= orderData.priceDetails.total.toFixed(2) %></span>
                                            </div>
                    </div>
                </div>
        </div>
    </div>

    <!-- Toast Notification -->
    <div id="toastNotification" class="toast"></div>

    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script>
        document.addEventListener('DOMContentLoaded', function () {
            // Toast notification function (using SweetAlert)
            function showToast(message, type = 'success') {
                const Toast = Swal.mixin({
                    toast: true,
                    position: 'top-end',
                    showConfirmButton: false,
                    timer: 3000,
                    timerProgressBar: true,
                    didOpen: (toast) => {
                        toast.addEventListener('mouseenter', Swal.stopTimer)
                        toast.addEventListener('mouseleave', Swal.resumeTimer)
                    }
                });

                Toast.fire({
                    icon: type,
                    title: message
                });
            }

            // Update order status
            const updateStatusBtn = document.getElementById('updateStatusBtn');
            if (updateStatusBtn) {
                updateStatusBtn.addEventListener('click', async function () {
                    const status = document.getElementById('statusSelector').value;

                    try {
                        const response = await fetch('/admin/editOrder/<%= orderData._id %>', {
                            method: 'POST',
                            headers: {
                                'Content-Type': 'application/json'
                            },
                            body: JSON.stringify({ status })
                        });

                        const result = await response.json();

                        if (result.success) {
                            showToast('Order status updated successfully');
                            setTimeout(() => {
                                window.location.reload();
                            }, 1000);
                        } else {
                            showToast(result.message || 'Failed to update status', 'error');
                        }
                    } catch (error) {
                        console.error('Error:', error);
                        showToast('An error occurred', 'error');
                    }
                });
            }

            // Approve return
            const approveReturnBtn = document.getElementById('approveReturnBtn');
            if (approveReturnBtn) {
                approveReturnBtn.addEventListener('click', async function () {
                    Swal.fire({
                        title: 'Approve Return?',
                        text: "This will refund the amount to customer's wallet",
                        icon: 'question',
                        showCancelButton: true,
                        confirmButtonColor: '#28a745',
                        cancelButtonColor: '#ff5252',
                        confirmButtonText: 'Yes, approve it!'
                    }).then(async (result) => {
                        if (result.isConfirmed) {
                            try {
                                const response = await fetch('/admin/returnOrder', {
                                    method: 'POST',
                                    headers: {
                                        'Content-Type': 'application/json'
                                    },
                                    body: JSON.stringify({
                                        orderId: '<%= orderData._id %>',
                                        orderStatus: 'Returned'
                                    })
                                });

                                const result = await response.json();

                                if (result.success) {
                                    Swal.fire(
                                        'Approved!',
                                        'Return has been approved and amount refunded.',
                                        'success'
                                    ).then(() => {
                                        window.location.reload();
                                    });
                                } else {
                                    Swal.fire(
                                        'Failed!',
                                        result.message || 'Failed to approve return',
                                        'error'
                                    );
                                }
                            } catch (error) {
                                console.error('Error:', error);
                                Swal.fire(
                                    'Error!',
                                    'An error occurred while processing return',
                                    'error'
                                );
                            }
                        }
                    });
                });
            }

            // Reject return
            const rejectReturnBtn = document.getElementById('rejectReturnBtn');
            if (rejectReturnBtn) {
                rejectReturnBtn.addEventListener('click', async function () {
                    Swal.fire({
                        title: 'Reject Return?',
                        text: "This will mark the order as delivered",
                        icon: 'warning',
                        showCancelButton: true,
                        confirmButtonColor: '#ff5252',
                        cancelButtonColor: '#00f2ea',
                        confirmButtonText: 'Yes, reject it!'
                    }).then(async (result) => {
                        if (result.isConfirmed) {
                            try {
                                const response = await fetch('/admin/returnOrder', {
                                    method: 'POST',
                                    headers: {
                                        'Content-Type': 'application/json'
                                    },
                                    body: JSON.stringify({
                                        orderId: '<%= orderData._id %>',
                                        orderStatus: 'Delivered'
                                    })
                                });

                                const result = await response.json();

                                if (result.success) {
                                    Swal.fire(
                                        'Rejected!',
                                        'Return request has been rejected.',
                                        'success'
                                    ).then(() => {
                                        window.location.reload();
                                    });
                                } else {
                                    Swal.fire(
                                        'Failed!',
                                        result.message || 'Failed to reject return',
                                        'error'
                                    );
                                }
                            } catch (error) {
                                console.error('Error:', error);
                                Swal.fire(
                                    'Error!',
                                    'An error occurred while processing return',
                                    'error'
                                );
                            }
                        }
                    });
                });
            }
        });
    </script>
</body>

</html>